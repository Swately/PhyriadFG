        const float w_b = clamp(smoothstep(0.35, 0.65, pc.t) + claim, 0.0, 1.0);
        mv = mix(mv_fwd, -mv_bwd, w_b);                              // STAGE-73/74: phase+claim-anchored primary
    }
    const vec2  sad_pair = texture(u_sad_field,       uv).xy;  // R=sad_best, G=sad_zero
    const float sad_best = sad_pair.r;
    const float sad_zero = sad_pair.g;

    // ── STAGE-77: the AMBIGUITY rule — runner-up arbitration of SAD ties (ambig_on > 0.5) ─────────
    // Inserted HERE — right after the phase+claim-anchored primary `mv` is finalized AND `sad_pair` is
    // sampled, but BEFORE Gate 2 consumes `mv` (t_mv_uv = mv·t, just below) — so the corrected mv
    // propagates COHERENTLY to every downstream consumer (the A/B warp samples, the matte advection
    // gathers, the crescent geometry), exactly like the STAGE-73 primary site one block up.
    //
    // THE CLASS: periodic textures (striped flags, concentric tunnels in the zoo). Their SAD landscape
    // has near-tied minima ~one texture-period apart; the matcher picks one ARBITRARILY (no awareness of
    // the runner-up) → the interior flickers between the two aliased vectors. B now ships the runner-up
    // (binding 10): cand.xy = the second-best MV, cand.z = its pure SAD. A tile is ALIASED when:
    //   aliased = (cand.z ≤ 1.15·sad_best)   — the runner-up is near-tied (a real SAD ambiguity, not noise),
    //         AND (|cand.xy − mv| > 2px)     — and it is a genuinely DIFFERENT vector (a texture-period away).
    //
    // THE REFEREE — gme_model_mv(uv): the smooth global background-motion model the gme holon fit this pair.
    // A periodic BACKGROUND interior has no true local structure to disambiguate it, so the correct vector is
    // the one nearest the global expectation (the camera/scene motion the surrounding non-periodic content
    // pinned). For NOT-matte_object pixels the referee is gme_model_mv(uv); for matte_object pixels we KEEP mv
    // (their field is already holon-arbitrated by the matte / object-inheritance repair — re-refereeing them
    // against the BACKGROUND model would be wrong, and the kickoff scopes v1 to the background/texture-interior
    // class). The rule therefore fires ONLY on NOT-matte_object pixels, where the referee is always the model.
    //
    // matte_object is the binary matte decision computed DOWNSTREAM (after this site, it needs the mv-advected
    // dissidence gathers). To stay acyclic AND conservative we use a mv-FREE OBJECT PROXY here: the per-pixel
    // SELF dissidence of EITHER anchor exceeding the matte threshold (the same masks + threshold the real
    // matte_object uses, minus the gathers). This OVER-covers object regions (it flags a pixel object wherever
    // either anchor's silhouette self-testimony is high — a superset of the gathered decision), so the rule is
    // SUPPRESSED on a superset of the true object pixels → it never re-refs a genuine object interior (the safe
    // bias). The proxy reads bindings 6/7 (the dissidence masks), valid only under gme → the rule is gated on
    // gme_on>0.5 too (which the host guarantees whenever ambig_on is set: use_ambig required the final use_gme).
    //
    // CONSERVATIVE v1: background/texture-interior aliasing is the class; object interiors are already repaired
    // and stay EXEMPT. OFF (ambig_on ≤ 0.5) leaves mv untouched → BYTE-IDENTICAL. One candidate tap, one model
    // eval, two dissidence taps, only when armed.
    if (pc.ambig_on > 0.5 && pc.gme_on > 0.5) {
        const vec4 cand    = texture(u_candidates, uv);                 // .xy = runner-up MV, .z = runner-up SAD
        const bool aliased = (cand.z <= 1.15 * sad_best) && (length(cand.xy - mv) > 2.0);
        // mv-free OBJECT proxy (a conservative superset of matte_object): either anchor's SELF dissidence
        // over the matte threshold. matte_thresh is the SAME quantized cutoff the real matte decision uses
        // (v = 16·r_px/255; both masks share it). Reads the dissidence masks only when matte_on is live;
        // off-matte (matte_thresh would be 0) there is no silhouette → proxy is false → all interiors are
        // background-eligible (the matcher had no object holon to protect them anyway).
        bool object_proxy = false;
        if (pc.matte_on > 0.5) {
            const float self_f = texture(u_dissidence,     uv).r;
            const float self_b = texture(u_dissidence_bwd, uv).r;
            object_proxy = (max(self_f, self_b) > pc.matte_thresh);
        }
        if (aliased && !object_proxy) {
            const vec2 referee = gme_model_mv(uv);                      // the smooth global background expectation
            // pick whichever of {mv, cand.xy} sits nearer the referee — the periodic interior should follow
            // the global motion the non-periodic surround pinned, not the matcher's arbitrary tie-break.
            mv = (distance(cand.xy, referee) < distance(mv, referee)) ? cand.xy : mv;
        }
    }

    // ── STAGE-90 (P2b): image-field-gated BACKGROUND SNAP — the disocclusion "gravity" fix ─────────
    // The optical-flow disocclusion artifact (LSFG/FSR3 have it too): near a moving object's boundary the
    // block-match assigns the OBJECT's MV to the fringe background pixels (bilinear bleed) → those bg pixels
    // warp TOWARD the object = the "gravity" (the operator's 2026-06-15 finding). The cure: at the IMAGE
    // boundary band (the iGPU Sobel field, binding 11 — the ground-truth edge LSFG has no access to), for the
    // BACKGROUND-side pixels, snap mv to the global background model (gme_model_mv) so they take the BACKGROUND
    // motion, then the A_samp/B_samp below re-sample COHERENTLY (no side-PICK like --fill-div → no flaming).
    //   THE BAND: the field is the Sobel of cur@phase1; the present is the warp@phase t, which fetches cur at
    //     uv+(1-t)·mv → the contour for present-p lives at p+(1-t)·mv. We ADVECT the field there (the SAME
    //     advection P1's --afill validated by eye: the contour sits ON the warped object).
    //   THE SIDE (photometric, matte-free): the object's own MV warps the object consistently (low d0); an
    //     attracted-bg pixel warped by the object MV lands its two anchors on contradictory content (high d0).
    //     bg = smoothstep(agree, 2·agree, d0). The dissidence/object_proxy is corrupted in exactly this band
    //     (attracted bg has the object MV → high dissidence) so it can't discriminate; d0 can.
    //   THE CONTINUUM (operator's holonic both-at-once): w = strength·band·bg; mv = mix(mv, gme_model_mv, w).
    //     strength=1 + a sharp band = HARD snap; strength<1 / soft band = SOFT blend (snap = the blend's limit).
    // HONEST WALL (dossier §10 F22/F23): holds the GLOBAL bg model → correct for static / camera-moving
    // background (the Zoo: static bg, works); a moving background behind a moving object is the near-irreducible
    // case (the model is wrong there — the snap is then a milder error than the gravity; dial strength down).
    // Gated on bg_snap_on>0.5 AND gme_on>0.5 (the model must be valid). OFF (≤0.5) ⇒ not entered ⇒ mv untouched
    // ⇒ BYTE-IDENTICAL. Cost when armed: 1 field imageLoad + 2 color taps, ONLY at band pixels (band==0 skips).
    float bgs_w = 0.0;   // STAGE-90c (P2b): the snap weight, hoisted for the late disocclusion FILL (after stasis)
    float bx_w  = 0.0;   // STAGE-95 (--band-xfade): the gravity-cancellation crossfade weight (bg-side band), hoisted to the final composite
    if ((pc.bg_snap_on > 0.5 && pc.gme_on > 0.5) || pc.band_xfade > 0.0) {
        const vec2  sz_s = vec2(out_size);
        // STAGE-90b (operator eye, 2026-06-15): the single-point band (the thin Sobel edge) reduced the gravity
        // DRASTICALLY but left a residual halo (~1 MV-block wide, from the block-MV bleed into the fringe
        // background) and made the strength dial invisible (a region too thin to show a 0.5↔1.0 gradient — the
        // residual halo dominates the view either way). The disocclusion halo is the region the object EDGE sweeps
        // through THIS pixel's motion segment — from the trailing position p−t·mv to the leading p+(1−t)·mv. So
        // sample the contour ALONG that segment and take the MAX → the band covers the full swept halo, not just
        // the edge. Parameter-free: the width IS the motion extent |mv| (fast object → wider disocclusion → wider
        // band), scale-correct by construction. ≤2px sample spacing, bounded to 12 taps (cheap on A's 4090).
        const int NS = clamp(int(length(mv) * 0.5) + 2, 3, 12);
        float band = 0.0;
        for (int k = 0; k < NS; ++k) {
            const float s  = mix(-pc.t, 1.0 - pc.t, float(k) / float(NS - 1));   // along the motion segment
            const ivec2 fk = clamp(ivec2(vec2(coord) + s * mv + 0.5), ivec2(0), out_size - ivec2(1));
            const uint  fl = imageLoad(u_field, fk).r;
            const float dk = float(fl & 0xffu);                                  // STAGE-G1 Sobel contour 0..255
            const float bk = (((fl >> 8u) & 0xffu) != 0u) ? clamp(dk * pc.bg_snap_norm, 0.0, 1.0) : 0.0;
            band = max(band, bk);                                                // the swept-halo band
        }
        if (band > 0.0) {
            // preliminary warp at the LOCAL (pre-snap) mv → the matte-free background discriminator d0.
            const vec2  t_off  = (mv * pc.t)         / sz_s;
            const vec2  it_off = (mv * (1.0 - pc.t)) / sz_s;
            const vec3  A0     = texture(u_prev_real, uv - t_off).rgb;
            const vec3  B0     = texture(u_cur_real,  uv + it_off).rgb;
            const float d0     = length(A0 - B0);
            const float bg     = smoothstep(pc.agreement_threshold, 2.0 * pc.agreement_threshold, d0);
            if (pc.bg_snap_on > 0.5 && pc.gme_on > 0.5) {
                const float w  = clamp(pc.bg_snap_strength * band * bg, 0.0, 1.0);
                mv = mix(mv, gme_model_mv(uv), w);                         // snap toward the background model
                bgs_w = w;                                                // hoist for the late disocclusion fill
            }
            // STAGE-95 (--band-xfade): the gravity-cancellation weight = band_xfade·band·bg. Hoisted to the
            // final composite (after stasis), where result is blended toward blend_result (the un-warped
            // cross-fade) on the bg-side band → the disocclusion "gravity" warp is replaced by the cancellation
            // (= clean static bg). Independent of the gme model (no snap). bg-side via the same photometric d0.
            if (pc.band_xfade > 0.0) bx_w = clamp(pc.band_xfade * band * bg, 0.0, 1.0);
        }
    }

    // ── Gate 1: Confidence ─────────────────────────────────────────────────────
    const bool good_match  = (sad_best < pc.residual_ceil);
    const bool good_improv = (sad_zero * (1.0 - pc.improvement_frac) > sad_best);

    // ── STAGE-94 (--vblend): velocity-continuity tilt of the A/B SAMPLE OFFSETS ─────────────────────
    // Each pair warps at its OWN single average velocity (its mv); at every pair BOUNDARY the velocity
    // STEPS from pair N's mv to pair N+1's mv → a perceived "pulse". Near the END of the pair (high phase
    // t) tilt the effective MV toward the NEXT pair's MV (mv_target, u_mv_target = the next-fresher
    // generation's forward field, available "for free" in the F→P ring) so the boundary velocity
    // transitions SMOOTHLY instead of stepping. w ramps 0->strength over t in [vblend_t0, 1]. Endpoint
    // PRESERVED: at t=1 the sample offsets are 0 regardless (t_mv_uv = mv·1·…, inv_t_mv_uv = mv·0·…), so
    // the result is still exactly cur whatever mv_fwd_eff is. ONLY the two warp sample offsets below use
    // mv_fwd_eff; EVERYTHING downstream (the occlusion-classification round-trip, the matte advection, the
    // crescent geometry, the rescue, the commit) keeps reading the RAW mv (and the raw bwd field), so the
    // classification's fwd↔bwd consistency test is UNCHANGED — only the displayed object position tilts.
    // OFF (vblend_on ≤ 0.5) → vb_w = 0 → mv_fwd_eff == mv → BYTE-IDENTICAL (u_mv_target never sampled).
    const float vb_w        = (pc.vblend_on > 0.5) ? (smoothstep(pc.vblend_t0, 1.0, pc.t) * pc.vblend_strength) : 0.0;
    // PREDICT mode: u_mv_target holds the PREV pair's MV field. The predicted NEXT-pair velocity (for C1
    // velocity continuity at the upcoming real frame) = mv_cur + (mv_cur − mv_prev) = 2·mv − mv_prev
    // (constant-acceleration extrapolation; the true next pair is not yet built — see the host note). When
    // there is no valid prev (ring edge), the host uploads mv itself → mv_prev==mv → target==mv → no tilt.
    const vec2  mv_ut       = (pc.vblend_on > 0.5) ? texture(u_mv_target, uv).xy : mv;
    const vec2  mv_target_s = (pc.vblend_exact > 0.5) ? mv_ut              // EXACT (STAGE-96): u_mv_target holds the REAL next-pair MV
                                                  : (2.0 * mv - mv_ut); // PREDICT (default): u_mv_target holds the PREV pair MV → 2·mv − mv_prev
    const vec2  mv_fwd_eff  = mix(mv, mv_target_s, vb_w);   // tilt the sample-offset MV toward it near the boundary (mv unchanged)

    // ── Gate 2: Source agreement — fetch warp samples UNCONDITIONALLY ──────────
    // (reused as the WARP result when both gates pass; the barrier below depends on them).
    const vec2 t_mv_uv     = (mv_fwd_eff * pc.t)           / vec2(out_size);
    const vec2 inv_t_mv_uv = (mv_fwd_eff * (1.0 - pc.t))   / vec2(out_size);
    const vec4 A_samp      = texture(u_prev_real, uv - t_mv_uv);
    const vec4 B_samp      = texture(u_cur_real,  uv + inv_t_mv_uv);
    const float d_pixel    = length(A_samp.rgb - B_samp.rgb);

    s_d[gl_LocalInvocationIndex] = valid ? d_pixel : 0.0;
    barrier();
    float d_sum = 0.0;
    for (uint i = 0u; i < 64u; ++i) d_sum += s_d[i];
    const float d_tile       = d_sum / 64.0;
    const bool  sources_agree = (d_tile < pc.agreement_threshold);

    // ── STAGE-53/53b: the fluid-matte — the DUAL-ANCHORED BINARY matte decision (matte_on > 0.5) ──
    // The operator's fluid-in-vessel principle: decide the BOUNDARY first (a binary matte = the
    // object vessel), then content can only fill its vessel — a rim pixel is pure object or pure
    // background, never a half-weight mix. The decision is computed HERE (after the primary MV, the
    // sad/gate quantities, and A_samp/B_samp are all known — all post-barrier, per-thread) and is
    // APPLIED LATE (after all of 41..52, just before the soft/hard selection) so the override sees
    // the finalized object-layer result. Gated wholly on matte_on > 0.5 (a uniform push value) →
    // the default (matte_on == 0) is byte-identical: NEITHER dissidence mask is sampled and
    // matte_object stays false (the override below never fires).
    //
    // STAGE-53b — the dual anchor (operator ball round 5): the prev-anchored mask alone advected
    // forward arrives LATE at the object's LEADING edge (object pixels momentarily classed background
    // → the model-layer bites). The cure is to anchor the silhouette at BOTH ends of the pair:
    //   · dis_fwd (PREV-anchored, u_dissidence, |mv−model| on the fwd grid = prev's lattice):
    //       dis_self   = the dissidence at this pixel's OWN cell (uv),
    //       dis_gather = the dissidence at the prev-side gather position (uv − mv·t/sz, the same
    //                    A-side displacement the warp uses → the advected silhouette covers both the
    //                    object's destination and the cell it came from). dis_fwd = max of the two.
    //   · dis_bwd (CUR-anchored, u_dissidence_bwd, |mv_bwd−model_bwd| on the bwd grid = cur's lattice):
    //       the cur silhouette advected BACKWARD toward prev. dis_self_b at uv and dis_gather_b at the
    //       cur-side position (uv + mv·(1−t)/sz, the B-side displacement). dis_bwd = max of the two.
    // ── STAGE-59 — the OCCUPANCY LERP (replaces the STAGE-53b UNION) ─────────────────────────────
    //   The union max(dis_fwd, dis_bwd) over-covers at large displacement (BOTH ends inflated) — the
    //   extreme-motion hallucination the operator saw at x2@120. The phase-t silhouette is correctly
    //   the t-WEIGHTED INTERPOLATION of the two anchored occupancies: at t~0 the prev-anchored wall
    //   dominates, at t~1 the cur-anchored, between them the interpolated shape. Both masks share the
    //   SAME R8 16x quantization, so matte_thresh (v = 16·r_px/255; 0.25 ↔ r ≈ 4 px) applies to the
    //   blended occupancy. matte_occ = mix(dis_fwd, dis_bwd, t); matte_object = matte_occ > thr.
    //   HONEST RISK (documented, the kickoff's "ship clean"): at mid-t with imperfect masks the lerp
    //   can THIN the silhouette where the union never did (a sliver covered by exactly one anchor is
    //   halved at t=0.5). The mass-conservation feedback (P-side, --mass-k>0) drops thr_effective when
    //   the presented mass falls below the t-lerp of the anchored masses → the vessel refills; the ball
    //   bench is the witness (mid-t fullness on; leading/trailing flex shrink vs the union).
    // STAGE-62: dis_fwd/dis_bwd are HOISTED to this scope (were locals inside the matte `if`) so the
    // crescent-directed background fetch (the matte BACKGROUND branch, far below) can REUSE the exact
    // anchored-dissidence values this invocation already computed — no second mask sample. They are
    // written ONLY inside `if (matte_on > 0.5)`; the crescent read is gated on the SAME matte_on>0.5,
    // so the read is always a subset of the write condition (the values are live wherever read). When
    // matte is off they keep these 0.0 defaults and nothing downstream reads them → byte-identical.
    float dis_fwd = 0.0;   // prev-anchored advected dissidence (max of self + prev-side gather)
    float dis_bwd = 0.0;   // cur-anchored  advected dissidence (max of self + cur-side gather)
    bool matte_object = false;
    // STAGE-71: the blended occupancy is HOISTED to this scope (was a local inside this `if`) so the
    // contour-marriage composition site (far below, the matte BACKGROUND override) can REUSE the exact
    // occupancy this invocation already computed for the boundary-band test |matte_occ − thr| < thr —
    // no second mask read. Written ONLY inside `if (matte_on > 0.5)`; the band test is gated on the
    // SAME matte_on>0.5 (via matte_push), so the read is always a subset of the write condition. When
    // matte is off it keeps this 0.0 default and nothing downstream reads it → byte-identical.
    float matte_occ = 0.0;
    if (pc.matte_on > 0.5) {
        const vec2  sz_m       = vec2(out_size);
        const float dis_self   = texture(u_dissidence, uv).r;
        const float dis_gather = texture(u_dissidence, uv - (mv * pc.t) / sz_m).r;
        dis_fwd                = max(dis_self, dis_gather);                                   // prev-anchored (FULL — crescent evidence)
        const float dis_self_b   = texture(u_dissidence_bwd, uv).r;
        const float dis_gather_b = texture(u_dissidence_bwd, uv + (mv * (1.0 - pc.t)) / sz_m).r;
        dis_bwd                = max(dis_self_b, dis_gather_b);                               // cur-anchored, advected back (FULL — crescent evidence)
        // ── STAGE-67: the OCCUPANCY decision — traveling silhouette (travel_on>0.5) ──────────────────
        //   The STAGE-59 lerp used the FULL anchored occupancies max(self,gather), but the SELF terms
        //   anchor the silhouette at BOTH end positions for the WHOLE pair → the swept band (between
        //   prev-pos and cur-pos) stays classified OBJECT until t≈0.75 (the residue/contamination the
        //   operator photographed). The cure: FADE the self crutches with phase (fwd self by (1−t), bwd
        //   self by t) so the phase-t silhouette TRAVELS; the gather terms — which carry the OBJECT's MV
        //   after the STAGE-61/63 field repair (the advected silhouette) — are kept at FULL weight, so
        //   the mask follows the object instead of smearing. Off (travel_on≤0.5) = the STAGE-59 lerp of
        //   the FULL max(self,gather) occupancies (byte-identical). The dis_fwd/dis_bwd ABOVE are the FULL
        //   testimonies and are UNCHANGED — only this occupancy reads the faded selves; the crescent below
        //   reads dis_fwd/dis_bwd (the full contamination evidence, correct regardless of phase).
        float occ_fwd; float occ_bwd;
        if (pc.travel_on > 0.5) {
            // ── STAGE-68: GATHER VALIDITY ─ a gather with no displacement is self in disguise. The
            //   occupancy gather reads uv ∓ mv·(…)/sz; when |mv|≈0 (static background the scene-memory
            //   kept) the gather lands on the OWN cell → gather ≡ self → the faded self crutch is
            //   smuggled back at full weight through the gather term → the remembered wake never fades
            //   (the yellow-ball trail the operator photographed). The cure: weight each gather by how
            //   FAR it actually displaced. g_f = smoothstep(0.5, 1.5, |mv|) in px (mv already per-pixel,
            //   pixel units): static blocks → g_f≈0 → the gather is faded to mix(1−t,1,0)=(1−t) (fwd) /
            //   t (bwd) like its self, so the whole testimony decays with phase (the wake fades no matter
            //   what the memory says); moving blocks (incl. the repair-armed cancellation interiors whose
            //   inherited |mv_obj|≥2px → g_f=1) keep the FULL traveling gather → the silhouette still
            //   follows the object. Constants are geometry (like the gather offsets), all inside travel_on
            //   → --no-travel reverts everything to the STAGE-59 lerp below (byte-identical).
            const float g_f = smoothstep(0.5, 1.5, length(mv));      // 0 = static gather (≡ self) → 1 = real travel
            occ_fwd = max(dis_self   * (1.0 - pc.t), dis_gather   * mix(1.0 - pc.t, 1.0, g_f));   // prev self fades; gather valid by |mv|
            occ_bwd = max(dis_self_b *        pc.t,  dis_gather_b * mix(       pc.t, 1.0, g_f));   // cur  self fades; gather valid by |mv|
        } else {
            occ_fwd = dis_fwd;                                         // STAGE-59: the full anchored occupancy
            occ_bwd = dis_bwd;
        }
        matte_occ              = mix(occ_fwd, occ_bwd, pc.t);                                 // the occupancy lerp (faded selves under travel)
        matte_object = (matte_occ > pc.matte_thresh);                                         // the t-interpolated traveling vessel
        // COLOR CROSS-CHECK (only where mv-guided armed → a color membership reference exists): an
        // OBJECT-matte pixel whose color matches NEITHER warped object sample is a matte false-
        // positive over open background (the dissidence flagged the object's MV residual but this
        // pixel actually shows background). c_pix = cur_real at uv (the pixel's own color — the same
        // membership reference guided_mv uses); compare max-channel against BOTH warped samples
        // A_samp/B_samp. If the NEARER of the two (min over the two distances) still exceeds
        // 2·commit_thresh — i.e. it matches neither object sample even loosely — demote to background.
        // Gated on commit_thresh > 0.0 (the color bar is expressed in commit_thresh units; with no
        // commit threshold there is no scale, so the cross-check is inert and the demotion is skipped).
        if (matte_object && pc.mv_guided > 0.5 && pc.commit_thresh > 0.0) {
            const vec3  c_pix = texture(u_cur_real, uv).rgb;
            const vec3  da    = abs(c_pix - A_samp.rgb);
            const vec3  db    = abs(c_pix - B_samp.rgb);
            const float d_a   = max(da.r, max(da.g, da.b));
            const float d_b   = max(db.r, max(db.g, db.b));
            if (min(d_a, d_b) > 2.0 * pc.commit_thresh) matte_object = false;
        }
    }

    // ── STAGE-72: the OBJECT-layer anchored claims (the symmetric crescent piece) ─────────────────
    // c_f/c_b are the EXACT STAGE-62 crescent weights — smoothstep(0.5·thr,1.5·thr,dis_fwd/dis_bwd),
    // thr = matte_thresh, the SAME quantization both masks share. 62's c_f/c_b are scoped away (locals
    // inside the matte BACKGROUND `if (pc.crescent_on>0.5)` block far below), so they are RECOMPUTED here,
    // identically, from the dis_fwd/dis_bwd the matte block already wrote (no re-sample). c_f = "the PREV
    // anchor claims this pixel as object"; c_b = the CUR anchor's claim. obj_cres gates BOTH consumers (the
    // A/B blend just below AND the commit side-pick): obj_crescent_on>0.5 AND matte_on>0.5 AND matte_object
    // (the OBJECT-classified pixels only). When off, obj_cres is false → c_f/c_b are 0 and unread → the
    // blend below stays the plain (1−t,t) average → byte-identical.
    const bool  obj_cres = (pc.obj_crescent_on > 0.5) && (pc.matte_on > 0.5) && matte_object;
    const float oc_thr   = pc.matte_thresh;
    const float c_f      = obj_cres ? smoothstep(0.5 * oc_thr, 1.5 * oc_thr, dis_fwd) : 0.0;   // prev anchor's object claim
    const float c_b      = obj_cres ? smoothstep(0.5 * oc_thr, 1.5 * oc_thr, dis_bwd) : 0.0;   // cur  anchor's object claim

    // ── WARP / BLEND ────────────────────────────────────────────────────────────
    // Both candidates are computed unconditionally (no barrier between here and the store).
    // Per-thread, post-barrier — no barrier between here and the store.
    // STAGE-72: the OBJECT layer's A/B blend upgrades from (1−t,t) to anchored-claim side weighting
    // (obj_cres only). w_A ∝ (1−t)·mix(1,c_f,k), w_B ∝ t·mix(1,c_b,k), k=1 (full claim gating), normalized;
    // both claims ≈ 0 (w_sum < 1e-4, the pixel sits where NEITHER anchor claims object) → fall back to the
    // plain (1−t,t) blend unchanged. Leading band (c_f≈0,c_b≈1): w_A≈0,w_B≈t → cur carries at ANY t; trailing
    // (c_b≈0,c_f≈1): prev carries. DEEP-OBJECT (c_f≈c_b≈1): mix(1,1,1)=1 both → w_A=(1−t),w_B=t → normalized =
    // (1−t,t) EXACTLY. blend_result (the soft-gate fallback cross-fade) is UNTOUCHED — only the warp side
    // carries the object's two warped samples; the claim weighting belongs to that average.
    // STAGE-81: the EFFECTIVE per-pixel A/B weights are materialized as a NORMALIZED (wa,wb) pair (wa+wb=1)
    // regardless of which form is live — the plain (1−t,t) blend OR the STAGE-72 anchored-claim weighting. The
    // disagreement collapse (just below) sharpens THIS pair toward winner-take-all where the two displaced
    // samples disagree. wa is the prev(A)-side weight; the composition is warp_result = wa·A_samp + wb·B_samp.
    float wa;
    if (obj_cres) {
        const float w_A   = (1.0 - pc.t) * mix(1.0, c_f, 1.0);   // k=1: mix(1,c_f,1) = c_f
        const float w_B   =        pc.t  * mix(1.0, c_b, 1.0);   // k=1: mix(1,c_b,1) = c_b
        const float w_sum = w_A + w_B;
        if (w_sum < 1e-4) {
            // ── STAGE-89: occlusion-aware one-sided commit at the OBJECT-layer disocclusion sliver ──────
            // Both anchors' object CLAIMS are ~0 (neither cleanly carries the object) — the symmetric
            // (1−t) fallback below averages two stale samples = the half-moon. The RAW dissidence
            // asymmetry still encodes which edge this is (leading: dis_bwd>dis_fwd → cur owns → wa→0;
            // trailing: dis_fwd>dis_bwd → prev owns → wa→1). asym ∈ [−1,1]; commit_w gates SOFTLY on its
            // magnitude so a TRUE tie (dis_fwd≈dis_bwd) keeps (1−t) EXACTLY (no mis-pick on ambiguity).
            // disoccl_commit_on ≤ 0.5 → commit_w forced 0 → wa = (1−t) → BYTE-IDENTICAL. dis_fwd/dis_bwd
            // already in scope (matte block) — NO new tap.
            const float wa_phase = (1.0 - pc.t);
            float wa_commit = wa_phase;
            if (pc.disoccl_commit_on > 0.5) {
                const float denom    = dis_fwd + dis_bwd + 1e-4;
                const float asym     = (dis_fwd - dis_bwd) / denom;   // >0 trailing (prev owns) / <0 leading (cur owns)
                const float side     = (asym > 0.0) ? 1.0 : 0.0;      // prev(A)=1 / cur(B)=0
                const float commit_w = smoothstep(0.05, 0.35, abs(asym)); // ambiguity-gated: tie → 0 → keep phase
                wa_commit = mix(wa_phase, side, commit_w);
            }
            wa = wa_commit;
        } else {
            wa = (w_A / w_sum);                   // anchored-claim side weighting (normalized; wb = 1 − wa)
        }
    } else {
        wa = (1.0 - pc.t);                        // the plain (1−t,t) blend (wb = t = 1 − wa)
    }
    // ── STAGE-81: DISAGREEMENT COLLAPSE — one position per pixel (onepos_on > 0.5) ────────────────
    // warp_result is a two-sample blend; with imperfect/zero mv the two displaced samples land on
    // DIFFERENT content = the double exposure (the ghost). When they AGREE (d_pixel small) blending is
    // safe (identical content, averaging only sharpens); when they DISAGREE, blending IS the ghost, so
    // the heavier side must paint ALONE. c = smoothstep(athr, 2·athr, d_pixel) is that evidence (0 =
    // anchors agree → today's blend EXACTLY; 1 = disagree → winner-take-all). The effective weights
    // sharpen: wa' = mix(wa, wa>wb?1:0, c); wb' = 1 − wa' (normalization preserved). d_pixel and
    // agreement_threshold are already in scope (the A/B fetch + Gate 2). Gated on onepos_on>0.5 → OFF
    // (≤0.5) leaves wa untouched (c never applied) → the composition is the plain two-sample blend,
    // BYTE-IDENTICAL. NO new tap/binding/barrier.
    if (pc.onepos_on > 0.5) {
        // STAGE-82 (the operator's factor-of-2 dial): the collapse ONSET is now scaled by onepos_band
        // (1.0 = the STAGE-81 behavior exactly). The residual faint crescents live in the SUB-THRESHOLD
        // band (small-but-nonzero disagreement = partial blends); lowering the band halves the ghost
        // each time — his "launch it toward infinity" — with the NOISE FLOOR as the honest limit
        // (band→0 = winner-take-all on genuinely intermediate content → flicker). The optimum is the
        // operator's camera's to find: --onepos-band F.
        const float athr = pc.agreement_threshold * max(pc.onepos_band, 0.01);
        const float c    = smoothstep(athr, 2.0 * athr, d_pixel);   // 0 = agree (blend) → 1 = disagree (collapse)
        const float wb   = 1.0 - wa;
        // STAGE-83 (the contour-static fix): the time-side winner (wa>wb) FLIPS at t≈0.5 — every
        // disagreeing contour pixel switches source mid-pair → the per-tick shimmer ("estática") the
        // operator sees on clean figures' edges. Where the anchors' testimonies DISPUTE ownership
        // (|cfs−cbs| large — the contour bands; pair-STABLE values), the winner is chosen by the
        // pixel's CLASS instead of the clock: an OBJECT pixel collapses toward the side that HAS the
        // object (the claiming anchor); a BACKGROUND pixel toward the CLEAN side (the non-claiming
        // anchor — the 62 non-contamination logic). Claim-less disagreement (the nameplate text — in
        // neither mask) keeps the time-side winner (its accepted mid-pair step). dis_fwd/dis_bwd/
        // matte_object are the hoisted matte-block values (0/false when matte off → pure time-side =
        // STAGE-81/82 exactly; no push change, no new taps).
        const float cfs83 = smoothstep(0.5*pc.matte_thresh, 1.5*pc.matte_thresh, dis_fwd);
        const float cbs83 = smoothstep(0.5*pc.matte_thresh, 1.5*pc.matte_thresh, dis_bwd);
        float winner;
        if (abs(cfs83 - cbs83) > 0.2) {
            winner = matte_object ? ((cfs83 > cbs83) ? 1.0 : 0.0)    // object: the claiming side has it
                                  : ((cfs83 > cbs83) ? 0.0 : 1.0);   // background: the clean side shows it
        } else {
            winner = (wa > wb) ? 1.0 : 0.0;                          // claim-less: the time side (the step)
        }
        wa = mix(wa, winner, c);                                     // sharpen toward the stable winner
    }
    vec4 warp_result = wa * A_samp + (1.0 - wa) * B_samp;
    vec4 blend_result = (1.0 - pc.t) * texture(u_prev_real, uv)
                      + pc.t * texture(u_cur_real, uv);

    // ── STAGE-48: bidirectional occlusion classification (occl_thresh > 0 selects) ────
    // Gate the WHOLE block on occl_thresh > 0.0 (a uniform push value) — NOT on any per-pixel
    // quantity — so the default (occl_thresh == 0, --bidir off) is byte-identical: the bwd
    // sampler (binding 5) is never read and warp/blend stay the averages above. All per-thread,
    // post-barrier; runs BEFORE the 47b/c commit machinery so an "inconsistent, NEITHER side
    // round-trips" pixel falls through to that safety net unchanged.
    if (pc.occl_thresh > 0.0) {
        const vec2 sz = vec2(out_size);   // full-res; the same scale the warp uses for mv→uv
        // Forward round-trip: follow mvf (prev→cur, px) to its landing in cur, read mvb there.
        // mvf == mv_fwd, the RAW prev-anchored forward field at uv (binding 2). STAGE-73 EXEMPTS the
        // classification from the phase-anchored blend: it deliberately compares the raw fwd vs raw bwd
        // fields, so feeding it the (partly −bwd) blended primary would corrupt the round-trip landing
        // at high t. mv_fwd is identical to the pre-STAGE-73 `mv` here (when phase_anchor_on==0, mv==mv_fwd
        // anyway → byte-identical). A co-visible pixel: mvf + mvb ≈ 0.
        const vec2  mvf      = mv_fwd;                          // MV_fwd at uv (pixel units, raw — pre-blend)
        const vec2  uv_cur   = uv + mvf / sz;                   // where uv's content lands in cur
        const vec2  mvb_fwd  = texture(u_motion_vectors_bwd, uv_cur).xy;
        const float e_fwd    = length(mvf + mvb_fwd);           // forward round-trip residual (px)
        // Backward round-trip: follow mvb0 (cur→prev) from uv to its landing in prev, read mvf2.
        const vec2  mvb0     = texture(u_motion_vectors_bwd, uv).xy;  // MV_bwd at uv (pixel units)
        const vec2  uv_prev  = uv + mvb0 / sz;                  // where uv's content came from in prev
        const vec2  mvf_bwd  = texture(u_motion_vectors, uv_prev).xy;
        const float e_bwd    = length(mvb0 + mvf_bwd);          // backward round-trip residual (px)

        const bool fwd_ok = (e_fwd <= pc.occl_thresh);
        const bool bwd_ok = (e_bwd <= pc.occl_thresh);
        // Four-way classification (the kickoff semantics):
        //   both round-trip  → consistent / co-visible → leave the average (sharp) untouched.
        //   exactly one      → that side OWNS the content (one-sided sampling — the correct
        //                       decision, not the temporally-nearest guess):
        //                         fwd_ok only → prev (A) owns; bwd_ok only → cur (B) owns.
        //   neither          → truly inconsistent → leave both as-is → fall through to the
        //                       47b/c commit machinery below (the unchanged safety net).
        if (fwd_ok != bwd_ok) {            // exactly one side is consistent → it owns the content
            // ── STAGE-49: mask-WEIGHTED one-sided blend (replaces the STAGE-48 HARD pick) ──────
            // The hard pick (warp_result = the winner sample outright) snapped at the e==occl_thresh
            // boundary → a hard seam along disocclusion rims. FSR3's shipping practice (dossier F6:
            // two disocclusion masks, mask-WEIGHTED blending; GPUOpen + the MIT shader source) blends
            // BOTH reprojections by a continuous mask, discarding a direction fully only DEEP in the
            // mask. We reproduce that with a weight from the round-trip-error RATIO: the winner is the
            // side that round-trips (small e), the loser the side that does not (large e).
            //   r = e_loser / (e_winner + 0.25)   (0.25-px floor avoids div-by-tiny when e_winner≈0)
            //   w_side = smoothstep(1.0, 3.0, r)  → r≥3 (loser ≫ winner) = fully one-sided (the old
            //   hard behavior); r≈1 (near-tie, the rim's soft edge) blends both sides ≈ the average.
            // The 47c soft-band discipline (continuous, no flip-flop across ticks/neighbours) applies.
            float e_winner; float e_loser;
            vec4  winner_samp; vec4 winner_real;
            if (fwd_ok) {                  // fwd round-trips, bwd does not → content lives in prev
                e_winner = e_fwd; e_loser = e_bwd;
                winner_samp = A_samp;                       // the prev-warped sample (one-sided)
                winner_real = texture(u_prev_real, uv);
            } else {                       // bwd round-trips, fwd does not → content lives in cur
                e_winner = e_bwd; e_loser = e_fwd;
                winner_samp = B_samp;                       // the cur-warped sample (one-sided)
                winner_real = texture(u_cur_real, uv);
            }
            const float r      = e_loser / (e_winner + 0.25);   // round-trip-error ratio (≥1 by class)
            const float w_side = smoothstep(1.0, 3.0, r);       // 0 near-tie → 1 deep in the mask
            // ── STAGE-116 (--disoccl-hardpick): edge-gated HARD pick (convergent guide #1, with OUR image-edge gate) ──
            // STAGE-49 SOFTENED the hard pick into this ratio-weighted blend to avoid a seam — but the soft blend at
            // the reveal band IS the smear/step/crescent ("media luna"). The iGPU Sobel field lets the hard pick
            // RETURN cleanly: at a TRUE contour the seam is invisible (it lands ON the real edge); in flat interior
            // we keep the soft blend (no seam). 3 taps along the motion segment (the swept halo, like STAGE-90 bg-snap),
            // max, occ-class-gated + bg_snap_norm-normalized — the SAME validated edge signal. 0 → not entered → identical.
            float w_use = w_side;
            if (pc.disoccl_hardpick > 0.0) {
                float ed = 0.0;
                for (int k = 0; k < 3; ++k) {
                    const float s  = mix(-pc.t, 1.0 - pc.t, float(k) * 0.5);          // -t .. (1-t) along the segment
                    const ivec2 fc = clamp(ivec2(vec2(coord) + s * mvf + 0.5), ivec2(0), out_size - ivec2(1));
                    const uint  fv = imageLoad(u_field, fc).r;
                    const float dk = (((fv >> 8u) & 0xffu) != 0u) ? float(fv & 0xffu) : 0.0;  // occ-class-gated Sobel 0..255
                    ed = max(ed, dk);                                                          // the swept-halo edge
                }
                ed = clamp(ed * pc.bg_snap_norm, 0.0, 1.0);                            // contour → [0,1]
                const float g = smoothstep(pc.disoccl_hardpick * 0.5, pc.disoccl_hardpick * 1.5, ed);
                w_use = mix(w_side, 1.0, g);   // true edge → HARD commit to the winner; flat interior → soft blend
            }
            warp_result  = mix(warp_result,  winner_samp, w_use);   // existing average → winner sample (edge-gated hard)
            blend_result = mix(blend_result, winner_real, w_use);   // existing cross-fade → winner real (edge-gated hard)
        } else if (!fwd_ok && pc.div_eps > 0.0) {
            // ── STAGE-50: NEITHER round-trips (genuine disocclusion sliver) + fill-div selected ──
            // (the else here is the both-ok-or-neither branch; !fwd_ok ⇒ !bwd_ok ⇒ the neither case.
            //  both-ok keeps the average untouched.) Pick the side by the sign of the forward-MV
            // divergence: expansion (div>0) reveals background present in cur (B); contraction
            // (div<0) occludes background present in prev (A). |div| within the band stays ambiguous
            // → fall through to 47b/c unchanged. 4 extra MV taps, only in this already-rare branch.
            const vec2  texel = 1.0 / vec2(textureSize(u_motion_vectors, 0));  // uv step = ±1 MV-grid texel
            const float dmvx_dx = (texture(u_motion_vectors, uv + vec2(texel.x, 0.0)).x
                                 - texture(u_motion_vectors, uv - vec2(texel.x, 0.0)).x) * 0.5;
            const float dmvy_dy = (texture(u_motion_vectors, uv + vec2(0.0, texel.y)).y
                                 - texture(u_motion_vectors, uv - vec2(0.0, texel.y)).y) * 0.5;
            const float div = dmvx_dx + dmvy_dy;        // pixels per MV-grid texel
            // ── STAGE-52: model-guided background MV for the disocclusion fill (gme_on > 0.5) ────────
            // The revealed background is being uncovered by a moving object; its TRUE motion is the
            // camera/background motion — the global affine model, NOT the local MV (which belongs to the
            // occluding object). The documented MEMC background-extension (dossier F5): sample the owning
            // real at the MODEL displacement instead of raw uv, so the fill carries the background's own
            // motion (sharp, correctly-placed) rather than a frozen un-displaced copy. Same sign/scale
            // the warp uses for the B/A side (B at +mv·(1−t)/sz, A at −mv·t/sz). Gated on gme_on>0.5
            // (uniform push) AND inside the already-fill-div-only branch → fill-div alone (gme off) is
            // byte-identical: the model offset collapses to zero and the raw-uv samples are kept.
            const vec2 sz_g    = vec2(out_size);
            const vec2 mv_g    = (pc.gme_on > 0.5) ? gme_model_mv(uv) : vec2(0.0);
            const vec2 boff_g  = (mv_g * (1.0 - pc.t)) / sz_g;        // cur(B)-side model displacement
            const vec2 aoff_g  = (mv_g * pc.t)         / sz_g;        // prev(A)-side model displacement
            if (div > pc.div_eps) {                     // divergence/expansion → revealed → cur owns
                warp_result  = (pc.gme_on > 0.5) ? texture(u_cur_real, uv + boff_g) : B_samp;
                blend_result = (pc.gme_on > 0.5) ? texture(u_cur_real, uv + boff_g) : texture(u_cur_real, uv);
            } else if (div < -pc.div_eps) {             // convergence/contraction → occluded → prev owns
                warp_result  = (pc.gme_on > 0.5) ? texture(u_prev_real, uv - aoff_g) : A_samp;
                blend_result = (pc.gme_on > 0.5) ? texture(u_prev_real, uv - aoff_g) : texture(u_prev_real, uv);
            }
            // |div| ≤ div_eps → ambiguous → leave both as-is → fall through to 47b/c.
        }
        // both-ok → average kept; neither-ok + fill-div off (or ambiguous) → fall through to 47b/c.
    }

    // ── STAGE-47: commit-don't-hedge (commit_thresh > 0 selects; 0 = averages above) ──
    // Gate the WHOLE override on commit_thresh > 0.0 (a uniform push value) — NOT on
    // d_ab — so the default (commit_thresh == 0) is byte-identical to the averages even
    // though d_ab > 0.0 holds wherever the two warped samples differ at all.
    if (pc.commit_thresh > 0.0) {
        // d_ab = max-channel abs diff between the two warped samples (color units).
        // Max-channel (not luminance): the ghost is a small high-contrast feature whose
        // divergence can live in ONE channel (a coloured detail); luminance's 0.2/0.7/0.1
        // weights would dilute a blue/red ghost. Max-channel catches any-channel split,
        // matches commit_thresh's per-channel [0,1] units, and is cheaper than a dot.
        const vec3  ab    = abs(A_samp.rgb - B_samp.rgb);
        const float d_ab  = max(ab.r, max(ab.g, ab.b));

        // ── STAGE-49: candidate-rescue (rescue_on > 0.5 selects; armed only with commit) ──────
        // Before this pixel — whose PRIMARY (binding-2) MV failed the d_ab commit trigger — falls to
        // the commit fallback, try the 8 NEIGHBOR block MVs as candidates (per-pixel MV by SELECTION,
        // dossier F1/F0: the small high-contrast feature the block MV got wrong often has its TRUE
        // vector in an adjacent block — the duck's eye carries the eye's MV). For each candidate mv_c
        // we re-warp A and B EXACTLY as the primary warp does (A at uv − t·mv_c/sz, B at uv +
        // (1−t)·mv_c/sz — the same sign/scale convention as t_mv_uv/inv_t_mv_uv above).
        //   ── STAGE-49b CHANGE (the flat-content blind spot): the score is a 3x3 full-res WINDOW SAD
        //     (window_sad above), not the single-pixel d_ab. A wrong MV that lands both samples on
        //     identical FLAT content scores ~0 single-pixel (dossier F2) so the old per-pixel score
        //     could not tell a wrong candidate from a right one inside a flat object → block stamps/
        //     holes at the moving rim. The window — the pixel + its 8 neighbours — straddles the edge
        //     and sees the disagreement. The PRIMARY is re-scored with the SAME window for a fair
        //     comparison (s_primary). Acceptance: best windowed candidate ≤ the windowed primary AND
        //     ≤ 9·commit_thresh (the per-position threshold scaled by the 9-position window sum — an
        //     average-per-position bar of commit_thresh, the natural windowed generalisation of the
        //     single-pixel `≤ commit_thresh` rule). The TRIGGER is unchanged: the single-pixel d_ab
        //     band still decides WHETHER rescue runs; the window decides WHICH candidate wins.
        // The whole loop runs ONLY here, inside `commit_thresh>0` AND only where d_ab already failed
        // (the rare branch); cost = (1 primary + 8 candidates) × 9 positions × 2 color taps WORST case
        // + 8 MV taps. We compute it BEFORE the 47c wc band so a rescued pixel skips the commit mix
        // entirely — the rescued average IS the warp-side result; blend_result is untouched.
        bool rescued = false;
        if (pc.rescue_on > 0.5 && d_ab > 0.75 * pc.commit_thresh) {   // only where wc would mix (band start)
            const vec2  out_sz    = vec2(out_size);
            const vec2  mv_texel  = 1.0 / vec2(textureSize(u_motion_vectors, 0));  // 1 MV-grid cell in uv
            const float s_primary = window_sad(uv, out_sz, mv);       // the primary MV, windowed (fair bar)
            float  best_s    = s_primary;             // a candidate must BEAT the windowed primary to win
            bool   have_best = false;
            vec4   best_warp = warp_result;
            for (int oy = -1; oy <= 1; ++oy) {
                for (int ox = -1; ox <= 1; ++ox) {
                    if (ox == 0 && oy == 0) continue;        // skip the center (the primary MV already failed)
                    const vec2  off  = vec2(float(ox), float(oy)) * mv_texel;
                    const vec2  mv_c = texture(u_motion_vectors, uv + off).xy;    // candidate MV (pixel units)
                    // ── STAGE-57 GATE (a): a static-history block REJECTS fast neighbour candidates ──────
                    // The interior cannot adopt an exterior neighbour's big MV via rescue (the 3rd-person
                    // character's rim adopting the world's vectors — the operator's directional contamination).
                    // Reject any candidate with |mv_c| > 2px for an inertia_static pixel. Gated on
                    // inertia_static (constant-false when inertia is off) → byte-identical when off. The
                    // primary MV — already in best_s as s_primary — is NEVER rejected here (own-match path).
                    if (inertia_static && length(mv_c) > 2.0) continue;
                    const float s_c  = window_sad(uv, out_sz, mv_c);             // candidate, same 3x3 window
                    if (s_c < best_s) {                       // track the best (lowest windowed-SAD) candidate
                        best_s    = s_c;
                        const vec4 A_c = texture(u_prev_real, uv - (mv_c * pc.t)         / out_sz);
                        const vec4 B_c = texture(u_cur_real,  uv + (mv_c * (1.0 - pc.t)) / out_sz);
                        best_warp = (1.0 - pc.t) * A_c + pc.t * B_c;   // the candidate's average (standard warp)
                        have_best = true;
                    }
                }
            }
            // ── STAGE-52: the GLOBAL MOTION MODEL as one extra rescue candidate (gme_on > 0.5) ───────
            // A fast camera pan moves more than the block-match search window → the local MV (and every
            // neighbour) is wrong, all scoring high. The global affine model — fitted from the WHOLE
            // field, robust to the moving objects — recovers the camera/background MV for exactly that
            // case. It is scored by the SAME windowed SAD and competes for best_s like any neighbour;
            // gated on gme_on>0.5 (a uniform push value) so the OFF path is byte-identical (this candidate
            // simply does not exist). The model MV is in the same pixel units / sign / scale as the field.
            // ── STAGE-57 GATE (c): a static-history block SKIPS the global-model candidate ──────────────
            // The global affine model IS the camera/background (exterior) motion by construction — exactly
            // what a static-history interior block must not adopt. Skip it entirely for an inertia_static
            // pixel (the && short-circuits the whole candidate). Byte-identical when inertia is off
            // (inertia_static is constant-false → the original `pc.gme_on > 0.5` condition stands).
            if (pc.gme_on > 0.5 && !inertia_static) {
                const vec2  mv_g = gme_model_mv(uv);                  // the affine-model MV (pixel units)
                const float s_g  = window_sad(uv, out_sz, mv_g);     // same 3x3 windowed SAD as the others
                if (s_g < best_s) {
                    best_s    = s_g;
                    const vec4 A_g = texture(u_prev_real, uv - (mv_g * pc.t)         / out_sz);
                    const vec4 B_g = texture(u_cur_real,  uv + (mv_g * (1.0 - pc.t)) / out_sz);
                    best_warp = (1.0 - pc.t) * A_g + pc.t * B_g;     // the model candidate's average
                    have_best = true;
                }
            }
            // Accept iff the best candidate beats the windowed primary (best_s < s_primary, implied by
            // have_best) AND clears the windowed acceptance bar 9·commit_thresh. The small feature found
            // a neighbour vector whose 3x3 window agrees across the edge → use that candidate's average.
            if (have_best && best_s <= 9.0 * pc.commit_thresh) {   // the small feature found its true vector
                warp_result = best_warp;                      // use the candidate average; commit skipped
                rescued     = true;
            }
        }

        // STAGE-47c: SOFT commit band. A hard `if (d_ab > thresh)` made pixels at the
        // boundary flip between average and commit across ticks/neighbours — the operator's
        // "static" speckle class. Instead, blend average→committed across a smoothstep band
        // [0.75·thresh, 1.25·thresh]: the boundary becomes a gradient, no flip-flop.
        // STAGE-49: a RESCUED pixel forces wc→0 (skip the commit mix entirely — the rescued
        // average is the warp-side result; blend_result is left as the soft-gate fallback).
        const float wc = rescued ? 0.0
                       : smoothstep(0.75 * pc.commit_thresh, 1.25 * pc.commit_thresh, d_ab);
        if (wc > 0.0) {
            // ── STAGE-72: the committed side RESPECTS the object claims (the bite cure, part 2) ─────────
            // The commit's side pick is time-nearest by default: t<0.5 → A (prev), else B (cur). At the
            // LEADING band (c_f≈0, c_b≈1) with t=0.25 the time-nearest pick is A (prev = BACKGROUND — the
            // object has not arrived there), so the commit drags warp_result back to background = the bite,
            // ERASING the part-1 A/B blend that correctly put cur. The fix: for an OBJECT pixel where one
            // anchor clearly CLAIMS the pixel and the other clearly does NOT, the committed side becomes the
            // CLAIMING anchor (commit_use_A reflects the claim, not the clock). Near-equal claims (incl.
            // DEEP-OBJECT c_f≈c_b — both anchors hold the object) keep the time-nearest pick (commit_use_A =
            // t<0.5), so the commit behavior of deep-object pixels is UNCHANGED. The decision is ONE boolean
            // threaded through every side-selector in this block + the appearance re-blend below (all of which
            // are side-selectors — the OTHER anchor / the committed fetch position — never phase weights; the
            // (1−t),t multipliers stay literal). Off (obj_cres false) → commit_use_A = (t<0.5) → byte-identical.
            //   The claim margin reuses the SAME c_f/c_b as part 1 (no new sample). |c_f − c_b| > 0.5 is a
            //   clear one-sided claim (one anchor ≥ the smoothstep upper knee, the other below the lower);
            //   then prefer the HIGHER-claim anchor: c_f > c_b → use A (prev claims), else use B (cur claims).
            const bool commit_claim_clear = obj_cres && (abs(c_f - c_b) > 0.5);
            const bool commit_use_A = commit_claim_clear ? (c_f > c_b) : (pc.t < 0.5);
            // Committed fallback (gated path) → nearest REAL, not the cross-fade double exposure.
            const vec4 near_real = commit_use_A ? texture(u_prev_real, uv) : texture(u_cur_real, uv);
            // MV is wrong for THIS pixel. Two commit targets:
            //  · warped (47):  nearest sample THROUGH the (bad) MV — keeps motion but fetches
            //    from the wrong position → displaced-copy edge fringe ("overdrive" glow, the
            //    operator's Predator-overshoot read; worse because subpixel misalignment at
            //    hard edges fires d_ab even on healthy MVs, so every moving contour commits).
            //  · real (47b):   nearest real UNWARPED at this uv — the pixel drops to source
            //    cadence locally (honest step; no ghost, no fringe).
            vec4 commit_target = (pc.commit_real > 0.5) ? near_real
                                                        : (commit_use_A ? A_samp : B_samp);
            // ── STAGE-64: appearance-band temporal re-blend on the committed value (appear_on > 0.5) ──
            // The commit is a ONE-SIDED pick: it shows a single anchor's color un-interpolated. When the
            // object's APPEARANCE (not position) changes between anchors — a brightness pulse, a shadow, a
            // reflection — that one-sided color is the WRONG-TIME tone (the operator's stains-of-the-previous-
            // tone on the pulsing zoo ball). If the two times agree on STRUCTURE but differ mildly in TONE
            // the phase-correct color is the temporal blend; if they differ a LOT it is a real displacement
            // (the reason commit exists) and the one-sided pick must stand. We measure that with ONE extra tap:
            // S_o = the OTHER anchor sampled at the SAME committed fetch position as the committed value S_n.
            //   commit-real  (commit_real>0.5): S_n is the unwarped near_real at uv → the other real at uv is
            //     S_o, and the phase-t blend at uv = (1−t)·prev[uv] + t·cur[uv] (== blend_result's base form).
            //   commit-warped(commit_real≤0.5): S_n is the warped nearest (A_samp@posA or B_samp@posB) → S_o is
            //     the OTHER real sampled AT that same warped position; the phase-t blend at that one position.
            // w_app = 1 − smoothstep(band, 2·band, dmax(S_n,S_o)): small tone gap → full temporal interp; large
            // structural gap → 0 (commit stands). One extra texture tap, committed pixels only, no new binding.
            // Gated on appear_on>0.5 (a uniform push value) → off = the committed value passes through unchanged
            // (byte-identical). Composes with the wc mix below exactly as commit_target did.
            if (pc.appear_on > 0.5) {
                // STAGE-72: the appearance re-blend keys off the COMMITTED side (commit_use_A), not the clock,
                // so it stays consistent when the claim overrode the time-nearest pick. s_n is always the
                // committed sample; s_o the OTHER anchor at the same committed position; the phase-t blend
                // reconstructs (1−t)·prev + t·cur with the right sample on each side regardless of which anchor
                // committed. The (1−t),t multipliers are phase weights and stay literal. Off (obj_cres false →
                // commit_use_A = t<0.5) → byte-identical to the pre-STAGE-72 appearance block.
                vec3 s_n; vec3 s_o; vec3 t_blend;
                if (pc.commit_real > 0.5) {
                    // committed position is the unwarped uv; S_n = near_real, S_o = the OTHER real at uv.
                    s_n     = commit_target.rgb;
                    s_o     = commit_use_A ? texture(u_cur_real, uv).rgb : texture(u_prev_real, uv).rgb;
                    t_blend = (1.0 - pc.t) * (commit_use_A ? s_n : s_o)
                            +        pc.t  * (commit_use_A ? s_o : s_n);   // (1−t)·prev[uv] + t·cur[uv]
                } else {
                    // committed position is the warped nearest sample's fetch position; the OTHER real there.
                    const vec2 pos = commit_use_A ? (uv - t_mv_uv) : (uv + inv_t_mv_uv);
                    s_n     = commit_target.rgb;
                    s_o     = commit_use_A ? texture(u_cur_real, pos).rgb : texture(u_prev_real, pos).rgb;
                    t_blend = (1.0 - pc.t) * (commit_use_A ? s_n : s_o)
                            +        pc.t  * (commit_use_A ? s_o : s_n);   // (1−t)·prev_pos + t·cur_pos
                }
                const vec3  ad_ap = abs(s_n - s_o);
                const float dmx_ap = max(ad_ap.r, max(ad_ap.g, ad_ap.b));   // max-channel tone gap
                const float w_app  = 1.0 - smoothstep(pc.appear_band, 2.0 * pc.appear_band, dmx_ap);
                commit_target.rgb  = mix(s_n, t_blend, w_app);
            }
            warp_result  = mix(warp_result,  commit_target, wc);
            blend_result = mix(blend_result, near_real,     wc);
        }
    }

    // ── STAGE-53: the BACKGROUND-layer override (matte_on > 0.5, applied LATE) ───────────────────
    // The matte decision (computed early, above) is APPLIED here — AFTER every existing machinery
    // (48 occlusion, 50 fill-div, 49 rescue, 47b/c commit) has finalized warp_result/blend_result —
    // and BEFORE the soft/hard selection below. For a matte=OBJECT pixel: nothing changes (the
    // existing 41..52 result stands, the operator's "content fills its vessel"). For a
    // matte=BACKGROUND pixel: BOTH warp_result and blend_result are overwritten with the SAME pure
    // global-model layer sample, so whichever branch the gate selects — and the soft branch's
    // mix(blend, warp, w) of two IDENTICAL values — yields that one value: no half-weight fringe can
    // survive on a background-classified pixel. This is the boundary-first point: the binary matte IS
    // the composite; there is NO blending between the two layers.
    //   bg = (1−t)·prev[uv − model·t/sz] + t·cur[uv + model·(1−t)/sz]. The global affine model is
    //   valid EVERYWHERE (including under/behind the object) and is sharp because it is exact for the
    //   background by construction. Same sign/scale the warp uses for the A/B sides. matte_on is set
    //   only when the model is valid for this generation, so gme_model_mv() always has live params.
    // ── STAGE-71: capture the OBJECT-layer color BEFORE the override overwrites it ───────────────
    // The matte composition is temporally split: the OBJECT layer is warp_result/blend_result built
    // through all of 41..64 (above); the BACKGROUND layer is `bg` (computed below). The binary decision
    // (!matte_object) overwrites both with bg for background pixels. The contour marriage (STAGE-71)
    // arbitrates PER PIXEL in the boundary band, so it needs BOTH layer colors simultaneously — so we
    // snapshot the object layer here, before the override can clobber it. (When matte is off these are
    // unused.)
    const vec4 obj_warp_71  = warp_result;
    const vec4 obj_blend_71 = blend_result;
    if (pc.matte_on > 0.5) {
        const vec2 sz_bg = vec2(out_size);
        const vec2 mv_bg = (pc.gme_on > 0.5) ? gme_model_mv(uv) : vec2(0.0);
        const vec4 bg_prev = texture(u_prev_real, uv - (mv_bg * pc.t)         / sz_bg);
        const vec4 bg_cur  = texture(u_cur_real,  uv + (mv_bg * (1.0 - pc.t)) / sz_bg);
        // ── STAGE-62: crescent-directed mask-weighted background fetch (crescent_on > 0.5) ──────────
        // A background-classified pixel sits in one of the two CRESCENTS where only ONE pair-side
        // actually shows background. The TRAILING crescent (object covered it in PREV, gone in CUR) has
        // a high prev-anchored dissidence dis_fwd → its prev-side model sample lands on OBJECT pixels =
        // the trail; the LEADING crescent has a high cur-anchored dissidence dis_bwd → its cur-side
        // sample is contaminated by the object not yet arrived at phase t. Re-weight each side by its
        // NON-contamination (dis_fwd/dis_bwd are the SAME values the matte block computed above — reused,
        // not re-sampled): c_f rises as the prev side becomes object, c_b as the cur side does; the side
        // weights are the (1−t,t) interpolation weights TIMES the side's non-contamination factor. This
        // is mask-WEIGHTED side fetch (FSR3's shipping form, dossier F6), NOT a hard one-sided pick.
        //   thr = matte_thresh (the quantization both masks share). Both sides contaminated
        //   (w_prev+w_cur < 1e-4, the ambiguous overlap) → fall back to the (1−t,t) blend unchanged.
        // Gated on crescent_on>0.5 (a uniform push value); OFF (or both contaminated) ⇒ the EXACT
        // (1−t)·bg_prev + t·bg_cur blend below → byte-identical to pre-STAGE-62.
        // STAGE-71: `bg` (the BACKGROUND layer) is now computed whenever matte_on>0.5 — NOT only for
        // background-classified pixels — because a band pixel classified OBJECT still needs bg as the
        // arbitration's background candidate. For object non-band pixels (contour off, or outside the
        // band) bg is DISCARDED below → byte-identical; the only added cost is its 2 fetches.
        vec4 bg;
        if (pc.crescent_on > 0.5) {
            const float thr    = pc.matte_thresh;
            const float c_f    = smoothstep(0.5 * thr, 1.5 * thr, dis_fwd);   // prev side → object-ness
            const float c_b    = smoothstep(0.5 * thr, 1.5 * thr, dis_bwd);   // cur  side → object-ness
            const float w_prev = (1.0 - pc.t) * (1.0 - c_f);
            const float w_cur  =        pc.t  * (1.0 - c_b);
            const float w_sum  = w_prev + w_cur;
            if (w_sum < 1e-4) {
                // ── STAGE-89: occlusion-aware one-sided commit at the BACKGROUND-layer crescent ─────────
                // Both sides are object-CONTAMINATED — the symmetric (1−t)·bg_prev+t·bg_cur fallback
                // averages two object-painted samples = the estela. Commit to the LESS contaminated side:
                // dis_fwd<dis_bwd → prev carries less object → bg_prev; dis_bwd<dis_fwd → bg_cur. Soft in
                // the asymmetry magnitude so a true tie keeps the phase blend EXACTLY (no mis-pick on a
                // genuinely ambiguous band — the honest wall). disoccl_commit_on ≤ 0.5 → commit_w 0 → the
                // EXACT (1−t,t) blend → BYTE-IDENTICAL. dis_fwd/dis_bwd already in scope — NO new tap.
                const vec4 bg_phase = (1.0 - pc.t) * bg_prev + pc.t * bg_cur;
                bg = bg_phase;
                if (pc.disoccl_commit_on > 0.5) {
                    const float denom_b  = dis_fwd + dis_bwd + 1e-4;
                    const float asym_b   = (dis_bwd - dis_fwd) / denom_b;  // >0 prev cleaner / <0 cur cleaner
                    const vec4  bg_side  = (asym_b > 0.0) ? bg_prev : bg_cur;
                    const float commit_w = smoothstep(0.05, 0.35, abs(asym_b)); // ambiguity-gated: tie → 0
                    bg = mix(bg_phase, bg_side, commit_w);
                }
            } else {
                bg = (w_prev * bg_prev + w_cur * bg_cur) / w_sum; // mask-weighted side fetch
            }
        } else {
            bg = (1.0 - pc.t) * bg_prev + pc.t * bg_cur;                      // the unchanged background blend
        }
        // ── STAGE-90: BROAD disocclusion commit — the crescent is the bg BASE blend (mask-weighted OR plain),
        // which the --no-matte localize pins HERE, not the rare w_sum<1e-4 fallback STAGE-89 caught. Under
        // --disoccl-commit, commit the WHOLE band to the LESS-contaminated side so the TRUE revealed background
        // shows: kills the crescent AND keeps the matte (so the background fills the band → no gravity, the
        // object does not stretch). asym from the same dis_fwd/dis_bwd; soft-gated so a genuine tie keeps the
        // blend EXACTLY (the honest wall). disoccl_commit_on ≤ 0.5 → cw 0 → bg untouched → BYTE-IDENTICAL. No new tap.
        if (pc.disoccl_commit_on > 0.5) {
            const float denom_w = dis_fwd + dis_bwd + 1e-4;
            const float asym_w  = (dis_bwd - dis_fwd) / denom_w;   // >0 prev cleaner → bg_prev / <0 cur cleaner → bg_cur
            const vec4  side_w  = (asym_w > 0.0) ? bg_prev : bg_cur;
            bg = mix(bg, side_w, smoothstep(0.05, 0.35, abs(asym_w)));
        }
        // ── STAGE-71: the CONTOUR MARRIAGE — per-pixel boundary arbitration by color affinity ───────
        // The masks are TIGHT (STAGE-70) yet the remaining bites/chunks survive: they live in the
        // CONTOUR BAND at block scale, where an 8px-block MV straddling the edge drags the wrong side's
        // content (background into the object = bites; object onto background = residue) regardless of
        // the binary classification. The error is SUB-BLOCK; no block-level mechanism can fix it. The
        // cure is appearance: in the boundary band — where the block-level occupancy is UNCERTAIN
        // (|matte_occ − thr| < thr, i.e. matte_occ ∈ (0, 2·thr), covering the bilinear transition zone
        // of the R8 masks) — arbitrate PER PIXEL between the two layer colors by which one the pixel's
        // OWN real color resembles. ref = the time-nearest real at uv (the same near_real the commit
        // machinery uses — re-tapped here since near_real is scoped inside the commit branch above and
        // not live at this site; ONE tap, band pixels only). d_o = maxch|ref − obj_c|, d_b = maxch|ref
        // − bg_c|; alpha_obj = (d_b + eps)/(d_o + d_b + 2·eps): closer to the object color ⇒ more object.
        // result = mix(bg, obj, alpha_obj). OUTSIDE the band: the EXACT binary decision as today
        // (!matte_object → bg; object → untouched). Gated on contour_on>0.5 (a uniform push value) →
        // off ⇒ the band test is never entered, the binary `else if (!matte_object)` below is the EXACT
        // pre-STAGE-71 override → byte-identical.
        // HONEST LIMIT: near_real's geometry is anchored at one end (the nearest pair frame) — the
        // arbitration reference carries a phase-distance bias bounded by t to the nearest anchor (worst
        // at t=0.5). The arbitration is still PER-PIXEL where the current failure is PER-BLOCK (8px
        // chunks) → it can only ever reduce the fringe to ≤ sub-block scale, not invent geometry.
        const float thr71 = pc.matte_thresh;
        if (pc.contour_on > 0.5 && abs(matte_occ - thr71) < thr71) {
            const vec3  ref71  = ((pc.t < 0.5) ? texture(u_prev_real, uv) : texture(u_cur_real, uv)).rgb;  // time-nearest real
            const vec3  dov    = abs(ref71 - obj_warp_71.rgb);   // affinity to the OBJECT layer (warp side)
            const vec3  dbv    = abs(ref71 - bg.rgb);            // affinity to the BACKGROUND layer
            const float d_o    = max(dov.r, max(dov.g, dov.b));
            const float d_b    = max(dbv.r, max(dbv.g, dbv.b));
            const float eps71  = 1e-3;
            const float alpha_obj = (d_b + eps71) / (d_o + d_b + 2.0 * eps71);   // 1 ⇒ pure object, 0 ⇒ pure bg
            warp_result  = mix(bg, obj_warp_71,  alpha_obj);
            blend_result = mix(bg, obj_blend_71, alpha_obj);
        } else if (!matte_object) {
            warp_result  = bg;   // outside the band, background-classified → the EXACT pre-STAGE-71 override
            blend_result = bg;
        }
        // outside the band, object-classified → warp_result/blend_result untouched (the 41..64 result).
    }

    // ── STAGE-56: the stasis decision (computed here, applied as the FINAL select below) ─────────
    // stz is sad_zero (the .g of u_sad_field) — ALREADY read above for Gate 1 (sad_zero), so this
    // costs ZERO extra taps (no new texture sample, no new binding, no shared array). A block with
    // stz ≤ stasis_thresh is identical in both pair frames → its interpolation at any t is that same
    // content. The `> 0.0` short-circuit makes `stasis` constant-false when off → byte-identical.
    const float stz    = sad_zero;                                          // == texture(u_sad_field, uv).g
    const bool  stasis = (pc.stasis_thresh > 0.0) && (stz <= pc.stasis_thresh);

    // ── STAGE-79: MEMBERSHIP BEATS THE BLEND — the member-commit boost (member_commit_on > 0.5) ──
    // The warp-vs-blend selection (just below) falls back to blend_result on object INTERIORS whose
    // photometric gates fail: a low-texture interior (the flat-content blind spot) has weak gate
    // margins, so Gate 1/Gate 2 hedge to the (1−t,t) cross-fade = the operator's GHOST-STEP (the
    // object materializes at its new position while a trace lingers at the old). But post-STAGE-61/63
    // the field INSIDE a tracked silhouette is holon-repaired — the motion is KNOWN there, the blend
    // hedge is obsolete timidity. member_strength scales the blend-fallback pressure DOWN for a
    // confident member. The OBJECT proxy is mv-free (acyclic) — the per-pixel SELF dissidence of either
    // anchor (the SAME proxy STAGE-77b uses for the ambiguity exemption, NO gathers), gated on the same
    // matte_on>0.5 that makes bindings 6/7 a valid silhouette. member_strength =
    // smoothstep(thr, 2·thr, max(self_fwd, self_bwd)), thr = matte_thresh (the SAME R8 quantization the
    // masks share). EXTREME escape: where the two warped samples disagree wildly (d_pixel >
    // 3·agreement_threshold — a real ambiguity, not the flat blind spot) the boost is SUPPRESSED so the
    // normal gate stands and genuine garbage still blends. Two dissidence taps, only when armed.
    // Gated on member_commit_on>0.5 AND matte_on>0.5 → OFF leaves member_strength = 0.0 → the soft mix
    // and the hard branch below are UNCHANGED → BYTE-IDENTICAL.
    float member_strength = 0.0;
    if (pc.member_commit_on > 0.5 && pc.matte_on > 0.5) {
        const float self_f = texture(u_dissidence,     uv).r;     // prev-anchored SELF dissidence (mv-free)
        const float self_b = texture(u_dissidence_bwd, uv).r;     // cur-anchored  SELF dissidence (mv-free)
        const float self_m = max(self_f, self_b);
        const bool  extreme = (d_pixel > 3.0 * pc.agreement_threshold);   // wild disagreement → real ambiguity
        member_strength = extreme ? 0.0 : smoothstep(pc.matte_thresh, 2.0 * pc.matte_thresh, self_m);
    }

    vec4 result;
    // ── STAGE-98 (--multicand): scored MULTI-CANDIDATE selection — "generate + discriminate + SELECT" ─────
    // SOTA-grounded (FG_VFI_PRIOR_ART §11). The field cannot recover GROUND TRUTH from two frames (VFI
    // ill-posed, F37) — this REDUCES artifacts by picking the most self-consistent candidate, it does NOT
    // recover the true motion. Mechanism = the MEDOID (F27 Apple nearest-to-consensus, robust to ONE
    // hallucinating outlier; no per-channel sort, no temperature to tune) over a candidate set we already
    // compute (no new bindings): the cascade-refined WARP, the two SINGLE-anchor warps (A-only=conceal side,
    // B-only=reveal side — F40 ASTRI half-length), plus speed-perturbed warps (generate-more, F44/F37). A
    // DISPERSION guard (open problem 6) falls to the safe crossfade where the candidates have no consensus —
    // EXCEPT on a true image edge, where the iGPU Sobel field (our differentiator vs LSFG/FidelityFX, F29/F43)
    // keeps the HARD pick so a linear-blend ghost is never painted across a real boundary. OFF (mc_on≤0.5) →
    // this whole branch is skipped → the existing soft_gate/hard path runs → BYTE-IDENTICAL.
    if (pc.mc_on > 0.5) {
        vec3 cand[7];
        int  K = 0;
        cand[K++] = warp_result.rgb;                  // 0: cascade-refined primary warp (sharp on co-visible)
        cand[K++] = A_samp.rgb;                        // 1: prev-only single anchor (the CONCEAL side, F40)
        cand[K++] = B_samp.rgb;                        // 2: cur-only  single anchor (the REVEAL  side, F40)
        if (pc.mc_nperturb >= 2.0) {                   // generate-more: speed-perturbed warps (F44/F37 speed ambiguity)
            const float p = pc.mc_perturb;
            cand[K++] = (wa * texture(u_prev_real, uv - (1.0 - p) * t_mv_uv) + (1.0 - wa) * texture(u_cur_real, uv + (1.0 - p) * inv_t_mv_uv)).rgb;
            cand[K++] = (wa * texture(u_prev_real, uv - (1.0 + p) * t_mv_uv) + (1.0 - wa) * texture(u_cur_real, uv + (1.0 + p) * inv_t_mv_uv)).rgb;
        }
        if (pc.mc_nperturb >= 4.0) {
            const float p2 = 2.0 * pc.mc_perturb;
            cand[K++] = (wa * texture(u_prev_real, uv - (1.0 - p2) * t_mv_uv) + (1.0 - wa) * texture(u_cur_real, uv + (1.0 - p2) * inv_t_mv_uv)).rgb;
            cand[K++] = (wa * texture(u_prev_real, uv - (1.0 + p2) * t_mv_uv) + (1.0 - wa) * texture(u_cur_real, uv + (1.0 + p2) * inv_t_mv_uv)).rgb;
        }
        // MEDOID: the candidate minimizing total L1 distance to the others = the robust consensus member.
        // O(K²) L1 (K≤7 → ≤49), no sort. The lone hallucinating candidate is the far outlier → never chosen.
        int   best    = 0;
        float bestTot = 1e30;
        for (int k = 0; k < K; ++k) {
            float tot = 0.0;
            for (int j = 0; j < K; ++j) tot += length(cand[k] - cand[j]);
            if (tot < bestTot) { bestTot = tot; best = k; }
        }
        vec3  sel  = cand[best];
        const float disp = bestTot / float(max(K - 1, 1));   // mean L1 of the medoid to the others = dispersion
        // EDGE GATE (our differentiator): the iGPU Sobel boundary at this pixel (low byte, 0..255 → 0..1).
        const float edge = float(imageLoad(u_field, clamp(coord, ivec2(0), out_size - ivec2(1))).r & 0xffu) / 255.0;
        // No consensus AND not a true edge → the crossfade is the safe degenerate (blur tolerable, geometry
        // jarring). On a true edge (edge ≥ mc_edge) keep the HARD medoid pick — never the linear-blend ghost.
        if (disp > pc.mc_disp && edge < pc.mc_edge) sel = blend_result.rgb;
        result = vec4(sel, warp_result.a);
    } else if (pc.soft_gate > 0.5) {
        // ── STAGE-46 soft mode: continuous gate weights (uniform push branch) ──────
        // Confidence: keep the hard sad_best ceiling (a true tolerance, not a margin),
        // soften the relative-improvement gate. Actual relative improvement of the match:
        //   improv = (sad_zero − sad_best) / sad_zero   (passes hard iff improv > improvement_frac)
        // Smoothstep centred on improvement_frac, half-width = improvement_frac/2 (clamped sane).
        const float improv     = (sad_zero - sad_best) / max(sad_zero, 1e-6);
        const float ci_mid     = pc.improvement_frac;
        const float ci_w       = clamp(0.5 * ci_mid, 0.01, 0.49);
        const float w_improv   = smoothstep(ci_mid - ci_w, ci_mid + ci_w, improv);
        const float w_conf     = good_match ? w_improv : 0.0;

        // Agreement: high weight when the tile mean d is well below the threshold; fades to 0
        // as d_tile crosses it. Smoothstep centred on agreement_threshold, half-width = thr/2.
        const float ag_mid     = pc.agreement_threshold;
        const float ag_w       = clamp(0.5 * ag_mid, 0.005, ag_mid);
        const float w_agree    = smoothstep(ag_mid + ag_w, ag_mid - ag_w, d_tile);

        // Isolated-block suppression: a pixel whose OWN source-disagreement d_pixel far
        // exceeds the TILE mean disagrees with all its tile neighbours → an isolated wrong-MV
        // stamp → fade toward freeze. Uses only the existing per-thread d_pixel + s_d-derived
        // d_tile (no new shared array). Tolerance band scaled off the agreement threshold.
        const float iso_band   = max(pc.agreement_threshold, 1e-3);
        const float w_neigh    = 1.0 - smoothstep(d_tile + iso_band, d_tile + 2.0 * iso_band, d_pixel);

        float w                = w_conf * w_agree * w_neigh;
        // STAGE-79: a confident member pulls w toward 1 (pure warp) — the blend-fallback pressure is
        // scaled down by (1 − member_strength): w' = mix(w, 1.0, member_strength). member_strength = 0
        // (off, or a non-member, or the extreme-disagreement escape) → w unchanged → byte-identical.
        w = mix(w, 1.0, member_strength);
        // ── STAGE-80: the COMMIT-DEFAULT flip — WARP IS THE DEFAULT (commit_default_on > 0.5) ──────────
        // Applied AFTER the mbb boost (which it composes with: mbb only RAISES w, the floor only raises it
        // further — neither lowers it). Post-STAGE-79 the cross-fade is the operator's dominant residual:
        // wherever w<1 (silhouette fringes, sub-mask text, unclustered detail the member boost does not
        // cover) the photometric gates still hedge to blend_result = (1−t)·prev[uv] + t·cur[uv] at FIXED
        // positions, so moving nameplate TEXT doubles (two phantom copies fading). The flip floors w at the
        // warp UNLESS the post-warp source disagreement d_pixel is genuinely large — the only honest evidence
        // the warp is wrong (the two warped anchors land on contradictory content). g = smoothstep(2·athr,
        // 4·athr, d_pixel): 0 where the anchors agree (trust the warp) → w floored to 1; 1 where they disagree
        // wildly (the warp IS wrong) → no floor, the photometric gate stands → blend. athr = agreement_threshold
        // (already in scope); d_pixel (already in scope, line ~709). NO new tap/binding/barrier. OFF (≤0.5) →
        // the floor never applies → w is exactly the STAGE-79 value → byte-identical.
        if (pc.commit_default_on > 0.5) {
            const float athr = pc.agreement_threshold;
            const float g    = smoothstep(2.0 * athr, 4.0 * athr, d_pixel);
            w = max(w, 1.0 - g);
        }
        result = mix(blend_result, warp_result, w);
    } else {
        // ── Hard mode: original binary path (default), or the STAGE-80 flip when armed ─────────────────
        // STAGE-79: a confident member (member_strength > 0.5, i.e. self-mask past the smoothstep
        // midpoint AND not the extreme-disagreement escape) selects warp_result even when a gate fails
        // — the holon-repaired interior commits to motion rather than hedging to the cross-fade. The
        // 0.5 cutoff is the binary analogue of the soft pull (member_strength = 0 when off → the
        // original binary path stands → byte-identical).
        // STAGE-80: under the COMMIT-DEFAULT flip the hard test inverts — WARP is the default, blend is
        // selected ONLY when the post-warp source disagreement is genuinely large (d_pixel > 2·athr, the
        // honest evidence the warp is wrong); the photometric AND (good_match&&good_improv&&sources_agree)
        // no longer FORCES the choice on its own. The mbb member escape composes unchanged (a confident
        // member still selects warp). OFF (commit_default_on ≤ 0.5) → the original binary path, byte-identical.
        bool pick_warp;
        if (pc.commit_default_on > 0.5) {
            pick_warp = (d_pixel <= 2.0 * pc.agreement_threshold) || (member_strength > 0.5);
        } else {
            pick_warp = (good_match && good_improv && sources_agree) || (member_strength > 0.5);
        }
        result = pick_warp ? warp_result : blend_result;
    }
    // ── STAGE-56: stasis override — the FINAL word, dominates everything above ───────────────────
    // After warp/commit/matte/soft have produced `result`, a stasis pixel (identical block in both
    // pair frames) is overwritten with the current real frame's content directly — immune to the
    // vector-lending every motion layer would otherwise apply. Off (stasis_thresh==0) → never fires.
    if (stasis) result = texture(u_cur_real, uv);

    // ── STAGE-90c (P2b, operator eye 2026-06-15): the disocclusion FILL — reconstruct the static
    // background the snap EXPOSED. The mv-snap (STAGE-90/90b) killed the gravity (the band MV becomes the
    // static background model), but at the disocclusion CORE the two anchors prev[uv]/cur[uv] differ — one
    // is the occluding object — and the downstream commit/onepos picks the TIME-nearest side → shows the
    // object half the phases → the static grid reads as ERASED (the operator's finding). For the REVEAL
    // (trailing) side the revealed content is the STATIC background, fully known in CUR. Reveal vs conceal
    // is the dissidence ASYMMETRY (the STAGE-89 signal, matte-free, valid under gme+bidir): dis_fwd>dis_bwd
    // ⇒ the object was in PREV here ⇒ REVEAL ⇒ the background is cur[uv] (cur at the snapped ≈static MV);
    // commit to it, strength-weighted by bgs_w. CONCEAL (db>df, object ARRIVING) is LEFT to the object's
    // own warp — filling it would erase the object's leading edge. Gated on bgs_w>0 (a snapped band pixel)
    // AND occl_thresh>0 (bidir ⇒ both dissidence masks are valid this generation). OFF (bg-snap off ⇒
    // bgs_w=0) ⇒ never fires ⇒ BYTE-IDENTICAL. 3 taps, only at the snapped band pixels.
    if ((bgs_w > 0.0 || bx_w > 0.0) && pc.occl_thresh > 0.0) {   // STAGE-95: bx_w also arms it (the --band-xfade HARD reveal-fill, standalone of bg-snap)
        const vec3  bgp   = texture(u_prev_real, uv).rgb;   // background candidate (prev, at the snapped ≈static MV)
        const vec3  bgc   = texture(u_cur_real,  uv).rgb;   // background candidate (cur,  at the snapped ≈static MV)
        const vec3  ad    = abs(bgp - bgc);
        const float disag = max(ad.r, max(ad.g, ad.b));
        // PIXEL-PRECISE disocclusion gate (operator eye, 2026-06-15): fill ONLY where the two static-MV
        // anchors DIFFER → a genuine disocclusion (one anchor is the occluding object, one is the revealed
        // background). This REJECTS the disc OVERLAP (object in BOTH frames: bgp≈bgc → no fill) so the fill
        // can NEVER paint the OBJECT's colour (the operator's "lines recover but in the object's colour"
        // bug — the block-res dissidence alone misclassified overlap pixels as reveal). It also rejects the
        // untouched static grid (bgp≈bgc background). The dissidence asymmetry then only chooses the SIDE.
        if (disag > pc.agreement_threshold) {
            const float df = texture(u_dissidence,     uv).r;   // prev-anchored object silhouette
            const float db = texture(u_dissidence_bwd, uv).r;   // cur-anchored  object silhouette
            // REVEAL (object was in PREV here) → bg = the CUR anchor. STAGE-95: under --band-xfade HARD-commit
            // cur bg (no blend → no color-deform, the operator's "lever b"); under --bg-snap legacy partial mix.
            if (df > db + 0.02) result.rgb = (bx_w > 0.0) ? bgc : mix(result.rgb, bgc, bgs_w);
        }
    }

    // STAGE-95 (--band-xfade): the band treatment is the one-sided HARD reveal-fill in the STAGE-90c block
    // ABOVE (gated on bx_w too) — NOT a symmetric crossfade. (The crossfade toward blend_result was a design
    // error: at the disocclusion CORE prev[uv]=object ≠ cur[uv]=bg, so (1−t)A+tB SMEARS object+bg = "arcs", and
    // a symmetric gate dirtied both the reveal AND the conceal side. The reveal-fill commits the CLEAN cur bg on
    // the reveal side and leaves the conceal to the object's warp.)

    // ── STAGE-59: the presented-mass workgroup reduction (unconditional barriers, OOB participates) ──
    // The PRESENTED mass = the count of OBJECT-classified pixels this dispatch (matte_object). We reduce
    // it per workgroup into the shared accumulator, then ONE atomicAdd into the host-visible counter at
    // local index 0 — never per pixel. The TWO barriers below are TOP-LEVEL and UNCONDITIONAL, exactly
    // like the s_d reduction barrier above: every invocation (incl. OOB, which contributes 0 because the
    // matte block ran with valid=false's coord but is gated below by `valid`) reaches both, so the
    // shared init→accumulate→flush ordering holds without uniform-control-flow violation. The whole
    // contribution is gated on matte_on>0.5 (a uniform push value): when matte is OFF nothing is added
    // (matte_object is constant-false anyway, and the flush is skipped) → the counter is untouched and
    // P's --mass-k feedback stays inert → byte-IDENTICAL output to pre-STAGE-59. atomicAdd on a `shared`
    // uint and on an SSBO member are core GLSL — no extension, no memory_order args.
    if (gl_LocalInvocationIndex == 0u) s_matte_cnt = 0u;
    barrier();
    if (valid && matte_object) atomicAdd(s_matte_cnt, 1u);
    barrier();
    if (gl_LocalInvocationIndex == 0u && pc.matte_on > 0.5)
        atomicAdd(u_matte_counter.matte_count, s_matte_cnt);

    // ── STAGE-91 (ASW): bounded forward EXTRAPOLATION — fill the throughput deficit instead of freezing ──
    // When B (the flow producer) falls behind, the sync-clock would HOLD the pair at phase 1 (a frozen
    // re-present = the stutter, the operator's deficit artifact). Instead, with --asw the present loop lets the
    // content_clock phase OVERSHOOT past 1 by `extrap` (bounded by --asw-max) and the object KEEPS MOVING: the
    // warp output above is the phase-1 result (≈ cur), and here we project the LATEST real (cur) FORWARD along
    // THIS pixel's own MV — the content now at uv came from uv-extrap*mv in cur. So motion continues smoothly
    // through the deficit (ASW / Oculus async space-warp). NO look-ahead: extrapolation projects forward from the
    // HELD pair, never reads an unpublished future generation (NG-3 safe; it is not a second interpolation). bg
    // pixels carry mv≈0 (especially under --bg-snap) so the static background does NOT move. Gated on pc.extrap>0
    // (host sends >0 only under --asw when the phase overshot) → OFF = BYTE-IDENTICAL. One cur tap when armed.
    if (pc.extrap > 0.0) {
        const vec2 euv = clamp(uv - pc.extrap * mv / vec2(out_size), vec2(0.0), vec2(1.0));
        result.rgb = texture(u_cur_real, euv).rgb;
    }

    // STAGE-97 (--ts-smooth): adaptive temporal smoothing — blend toward the PREVIOUS output frame ONLY on
    // low-confidence/garbage pixels (high source-disagreement = disocclusion/gravity), keeping clean pixels
    // sharp+fast (asymmetric). prev_output[uv] is the previous final frame (same uv; no motion-comp → it
    // trails on moving content, hence the garbage-gate to confine it to artifact pixels). garbage_w is built
    // from d_pixel (the post-warp source disagreement, already in scope: 0 = the two warped anchors agree =
    // clean → no blend; high = they disagree = flow failure/disocclusion = garbage → full blend). MUST be the
    // LAST modification of result (after the stasis/reveal-fill/extrap overrides). OFF (ts_smooth==0) → no
    // blend → BYTE-IDENTICAL.
    if (pc.ts_smooth > 0.0) {
        const float garbage_w = clamp(smoothstep(pc.agreement_threshold, 3.0*pc.agreement_threshold, d_pixel), 0.0, 1.0);
        result = mix(result, texture(u_prev_out, uv), pc.ts_smooth * garbage_w);
    }
    if (valid) imageStore(u_output, coord, result);
}
