shared float s_d[64];
shared uint  s_matte_cnt;   // STAGE-59: per-workgroup presented-object-pixel accumulator (matte mass)

// ── STAGE-49b: 3x3 full-res window SAD for a candidate (or primary) MV ──────────────
// The single-pixel d_ab CANNOT discriminate a wrong vector that lands both samples on
// identical FLAT content (yellow-yellow / bg-bg) — it scores ~0 for the wrong MV exactly
// like the right one (dossier F2). A small WINDOW does: score the pixel AND its 8 immediate
// full-res neighbours (±1 pixel in uv) by the same warp at the SAME mv, summing the
// max-channel |A−B| over the 9 positions. A window that straddles the moving edge sees the
// disagreement the centre flat pixel hides. Same sign/scale as the primary warp per position
// (A at uv'−t·mv/sz, B at uv'+(1−t)·mv/sz). Returns the SUM over 9 positions (range [0, 9·1]);
// the caller compares against 9·commit_thresh (the per-position threshold scaled by the window
// size — an AVERAGE-per-position bar of commit_thresh). 9 positions × 2 color taps per call.
float window_sad(vec2 uv, vec2 sz, vec2 mv) {
    const vec2 px      = 1.0 / sz;                       // one full-res pixel in uv
    const vec2 t_off   = (mv * pc.t)         / sz;       // A displacement (uv)
    const vec2 it_off  = (mv * (1.0 - pc.t)) / sz;       // B displacement (uv)
    float s = 0.0;
    for (int wy = -1; wy <= 1; ++wy) {
        for (int wx = -1; wx <= 1; ++wx) {
            const vec2 uvw = uv + vec2(float(wx), float(wy)) * px;   // neighbour position
            const vec4 A_w = texture(u_prev_real, uvw - t_off);
            const vec4 B_w = texture(u_cur_real,  uvw + it_off);
            const vec3 ab  = abs(A_w.rgb - B_w.rgb);
            s += max(ab.r, max(ab.g, ab.b));
        }
    }
    return s;
}

// ── STAGE-49c: bilateral (color-membership) PRIMARY MV fetch ─────────────────────────────
// The MV texture is sampled with LINEAR filtering, so a rim pixel straddling the MV-grid
// boundary between the moving ball's cell and the background cell receives a MIXED ball/bg MV
// — wrong for BOTH (the staircase the operator photographed). Under mv-guided we choose a
// SINGLE corner by color membership instead of blending the two.
//
// LINEAR-equivalence derivation (so the OFF path is byte-identical and the corner set is the
// EXACT one bilinear would interpolate). GLSL `texture(samp, uv)` with LINEAR filtering and a
// texture of size G computes the continuous texel coordinate s = uv*G − 0.5; the four texels
// it blends are the integer corners i00 = floor(s), i10 = i00+(1,0), i01 = i00+(0,1),
// i11 = i00+(1,1), with bilinear weights f = fract(s): result = mix(mix(T[i00],T[i10],f.x),
// mix(T[i01],T[i11],f.x), f.y). Each texel i has its CENTRE at uv (i+0.5)/G — so a corner's
// block-centre color is cur_real at (corner+0.5)/G, the SAME mapping the median pass uses.
// We texelFetch exactly those four floor/ceil corners (clamped to the grid), so the candidate
// set IS the bilinear footprint. When no corner wins decisively we RETURN the bilinear
// texture() result verbatim → for mv_guided ≤ 0.5 the caller never calls this and the fetch
// stays `texture(...)`, so OFF is byte-identical by construction (this function is unreached).
//
// Selection: c_pix = cur_real at uv (the pixel's own membership color); for each of the 4
// corners sample its block-centre color, score max-channel |c_pix − c_corner|; the winner is
// the min-score corner (winner-take-all). NEAR-TIE / NONE-SIMILAR fallback to bilinear:
//   · none similar — even the best corner's color differs by > sim_thresh (the pixel belongs
//     to neither cell's object, e.g. a thin feature) → no membership decision → bilinear.
//   · near tie — the two best corners score within sim_thresh of each other (the pixel sits
//     inside one color object spanning both cells; both corners are valid) → bilinear is the
//     right (smooth) answer, picking one would inject a discontinuity. (sim_thresh reused as
//     the tie band — same color-membership scale as the consensus pass.)
vec2 guided_mv(vec2 uv, float sim_thresh) {
    const vec2  grid     = vec2(textureSize(u_motion_vectors, 0));
    const vec2  inv_grid = 1.0 / grid;
    const ivec2 mxc      = ivec2(grid) - ivec2(1);
    const vec2  s        = uv * grid - vec2(0.5);          // bilinear continuous texel coord
    const ivec2 i00      = ivec2(floor(s));                // floor corner (bilinear footprint)
    const ivec2 corn[4]  = ivec2[4](i00, i00 + ivec2(1,0), i00 + ivec2(0,1), i00 + ivec2(1,1));
    const vec3  c_pix     = texture(u_cur_real, uv).rgb;   // the pixel's own membership color
    int   best_i = 0; float best_d = 1e9; float second_d = 1e9;
    for (int k = 0; k < 4; ++k) {
        const ivec2 ci  = clamp(corn[k], ivec2(0), mxc);
        const vec3  c_c = texture(u_cur_real, (vec2(ci) + vec2(0.5)) * inv_grid).rgb;
        const vec3  ad  = abs(c_pix - c_c);
        const float dmx = max(ad.r, max(ad.g, ad.b));      // max-channel membership distance
        if (dmx < best_d)      { second_d = best_d; best_d = dmx; best_i = k; }
        else if (dmx < second_d) { second_d = dmx; }
    }
    // none similar (best corner still > band) OR near-tie (two corners within band of each
    // other) → bilinear is the correct answer. Otherwise commit to the winning corner's MV.
    if (best_d > sim_thresh || (second_d - best_d) <= sim_thresh) {
        return texture(u_motion_vectors, uv).xy;           // the standard LINEAR result
    }
    return texelFetch(u_motion_vectors, clamp(corn[best_i], ivec2(0), mxc), 0).xy;
}

// ── STAGE-52: evaluate the global affine motion model at this pixel's mv-grid position ───────
// The CPU fits mv_model(gx,gy) = (a + b·gx + c·gy, d + e·gx + f·gy) over INTEGER grid indices
// (gx,gy) ∈ [0,G.x)×[0,G.y) where G = textureSize(u_motion_vectors,0) (the MV grid, mvw×mvh). The
// MV texture is sampled with LINEAR filtering: GLSL `texture(samp, uv)` maps uv to the continuous
// texel coordinate s = uv·G − 0.5, and at a texel CENTRE uv = (i+0.5)/G that gives s = i exactly.
// So evaluating the affine model at (gx,gy) = uv·G − 0.5 reproduces, on the lattice, the SAME grid
// position the CPU fit used → the model the shader computes per pixel is consistent with the field
// the fit was derived from (and with how the warp samples the bilinear MV). Result in PIXEL units
// (the stored MV unit), used exactly like a sampled MV downstream.
vec2 gme_model_mv(vec2 uv) {
    const vec2 grid = vec2(textureSize(u_motion_vectors, 0));
    const vec2 g    = uv * grid - vec2(0.5);          // bilinear texel coord = grid index at centres
    return vec2(pc.gme_a + pc.gme_b * g.x + pc.gme_c * g.y,
                pc.gme_d + pc.gme_e * g.x + pc.gme_f * g.y);
}

void main() {
    const ivec2 coord    = ivec2(gl_GlobalInvocationID.xy);
    const ivec2 out_size = imageSize(u_output);
    const bool  valid    = (coord.x < out_size.x && coord.y < out_size.y);

    // ── STAGE-114b (--camera-twarp): PER-PIXEL responsiveness lead on the SAMPLING base ───────────────
    // Each pixel leads FORWARD by ITS OWN motion (the MV field at this pixel) — NOT a global-uniform shift.
    // A uniform lead (STAGE-114 used the gme average translation) deforms the NON-uniform scene (parallax: near
    // moves more than far; + the mouse-look camera rotation) → the operator's "jelly" wobble (parts lag, then
    // settle). The per-pixel MV lead is CONSISTENT with the warp's own per-pixel motion → no deformation. `uv`
    // is the SAMPLING base for the ENTIRE warp (MV read, A/B blend, matte, dissidence, sad, persistence,
    // ts-smooth, extrap); the store below uses the ORIGINAL integer `coord` (only SAMPLING shifts). pc.cam_lead.x
    // carries the lead scalar `amt` (host: cfg.camera_twarp ? amt : 0; no gme dependency — the lead is the MV).
    // OFF → amt=0 → uv==uv0 → BYTE-IDENTICAL. The revealed screen edge is the sampler's clamp-to-edge (a tiny
    // bounded stretch). SIGN: +mv continues the motion forward (same direction as the B/cur sample); eye-tunable
    // (negate amt host-side if the lag worsens). The edge of an INDEPENDENTLY-moving object leads by its own MV
    // (correct); only the disocclusion BOUNDARY (ambiguous MV) can fray — the matte/bg-snap already covers it.
    const vec2 uv0 = (vec2(coord) + vec2(0.5)) / vec2(out_size);
    // STAGE-114c: lead by the SMOOTH gme AFFINE model (gme_model_mv) instead of the raw per-pixel MV. The raw
    // MV's per-pixel NOISE, amplified by the lead, wobbled the image = the operator's "underwater" refraction
    // (the lead samples THROUGH the MV field like light through moving water; MV noise → ripple). The affine
    // model varies SMOOTHLY across the frame (it captures the camera pan/yaw/zoom — the mouse-look motion that
    // IS the responsiveness symptom) with NO per-pixel noise → kills the underwater AND keeps the per-pixel
    // spatial variation that killed the global-uniform "jelly". Falls back to the raw MV when gme is off
    // (--no-gme). amt = pc.cam_lead.x; cam_lead.x<=0 (OFF) → _lmv=0 → uv==uv0 → BYTE-IDENTICAL (no extra work).
    const vec2 _lmv = (pc.cam_lead.x <= 0.0) ? vec2(0.0)
                    : (pc.gme_on > 0.5)      ? gme_model_mv(uv0)
                    :                          texture(u_motion_vectors, uv0).xy;
    const vec2 uv = uv0 + _lmv * pc.cam_lead.x / vec2(out_size);

    // ── STAGE-57: the inertia prior — read the per-block persistence ONCE (only when armed) ───────
    // p ∈ [0,1] = the static-history counter / 255. inertia_on gates the whole prior on the uniform
    // push value inertia_thresh > 0.0 → when off, NO persistence tap (byte-identical) and inertia_static
    // is constant-false, so none of the three gates below ever fire. inertia_static = this block has a
    // SUSTAINED static history (p ≥ thresh) → it must not adopt exterior motion through ambiguity paths.
    const bool  inertia_on     = (pc.inertia_thresh > 0.0);
    const float inertia_p      = inertia_on ? texture(u_persistence, uv).r : 0.0;
    const bool  inertia_static = inertia_on && (inertia_p >= pc.inertia_thresh);

    // STAGE-49c: PRIMARY MV fetch. mv_guided ≤ 0.5 (default OFF) keeps the EXACT LINEAR sample —
    // byte-identical to pre-STAGE-49c (guided_mv is never entered, the fetch is the same
    // `texture(...)` call). mv_guided > 0.5 picks ONE MV-grid corner by color membership
    // (bilateral upsampling, see guided_mv); the selected mv feeds A_samp/B_samp and EVERYTHING
    // downstream exactly as the bilinear mv did. The rescue loop's candidate MVs keep their own
    // texelFetch (they are already discrete) — only this primary fetch is bilateral.
    //   Membership band: the push grows by ONLY mv_guided (40→44B). The band is carried IN that
    //   one float by the host as mv_guided = 1.0 + sim_thresh (sim_thresh ∈ [0.02,0.5], so
    //   mv_guided ∈ [1.02,1.5] > 0.5 satisfies the gate AND encodes the band) → the warp recovers
    //   sim = mv_guided − 1.0, the SAME --mv-sim value the consensus pass uses (one membership
    //   scale). OFF (mv_guided = 0.0) never enters the branch, so the encoding is irrelevant there.
    vec2  mv             = (pc.mv_guided > 0.5)
                         ? guided_mv(uv, pc.mv_guided - 1.0)
                         : texture(u_motion_vectors, uv).xy;   // pixel units
    // ── STAGE-57 GATE (b): no fast-corner lending into a static-history block ──────────────────────
    // The bilateral fetch may select a FAST color-matched corner (the moving ball's MV bled into a slow
    // rim pixel via color membership). For a static-history block (inertia_static) we REFUSE that fast
    // corner and fall back to the plain LINEAR result — the interior cannot adopt exterior speed through
    // the membership path. Only the GUIDED fetch is gated (the LINEAR path is the block's own bilinear
    // MV, never restricted). Gated on inertia_static AND |mv_guided| > 2px → byte-identical when inertia
    // is off (inertia_static is constant-false). One extra LINEAR tap only when the gate actually fires.
    if (pc.mv_guided > 0.5 && inertia_static && length(mv) > 2.0) {
        mv = texture(u_motion_vectors, uv).xy;   // the standard LINEAR (bilinear) result — no fast corner
    }
    // ── STAGE-73: the PHASE-ANCHORED primary MV (phase_anchor_on > 0.5) ──────────────────────────
    // At this point `mv` is the PREV-anchored forward primary (the guided/linear fetch above, with the
    // inertia gate applied) — the value EVERY consumer used pre-STAGE-73. The fwd field lives at the
    // content's PREV positions; at high phase t the content has travelled 2-4 blocks past where its
    // vectors live → stale-vector fetches (the operator's outdump damage that grows with t). The cure:
    // anchor the field to the instant NEAREST t. mv_fwd = this prev-anchored primary (KEPT for the
    // round-trip classification, which deliberately compares the raw fwd vs raw bwd fields — see below).
    // mv_bwd = the cur-anchored backward field at uv (binding 5, the SAME linear fetch the classification
    // uses on that binding), NEGATED: the bwd field maps cur→prev, the warp's forward convention wants
    // mv_true ≈ −mv_bwd at cur-anchored positions. Blend by phase: w_b = smoothstep(0.35,0.65,t) → at
    // t≤0.35 mv = mv_fwd EXACTLY (byte-identical to today), at t≥0.65 mv = −mv_bwd (the cur-anchored
