    // phase_anchor_on>0.5 AND occl_thresh>0.0 (the bwd field is valid this generation — the host sets
    // phase_anchor_on 1.0 only under use_bidir && bwd_ok, which is exactly the occl_thresh>0 condition;
    // the redundant occl_thresh guard makes a stale push reading an unbuilt bwd field impossible). OFF
    // (phase_anchor_on ≤ 0.5) leaves mv = mv_fwd untouched → BYTE-IDENTICAL. ONE extra bwd MV tap, armed
    // only. The classification below keeps mv_fwd for its fwd leg (its semantics are UNCHANGED).
    const vec2 mv_fwd = mv;   // the prev-anchored forward primary — the classification's raw fwd leg
    if (pc.phase_anchor_on > 0.5 && pc.occl_thresh > 0.0) {
        const vec2  mv_bwd = texture(u_motion_vectors_bwd, uv).xy;   // cur-anchored field (cur→prev), pixel units
        // STAGE-74 (supervisor, outdump round 2): the pure phase blend BITES the t-silhouette's
        // TRAILING band at high t — the cur field has no object knowledge there (it is background in
        // cur) so −mv_bwd≈0 paints background INTO the object; symmetric at low t for the leading
        // band (the operator's "the mechanism believes the new frame and contaminates the object").
        // CLAIM modulation: the per-pixel SELF testimonies (mv-free → acyclic; the gathers need mv,
        // the selves do not) pull the blend toward the anchor that CLAIMS this pixel's content:
        // trailing band = prev claims (cfs high, cbs low) → fwd; leading = cur claims → −bwd; bulk =
        // both claim → pure phase. Gated on matte_on (bindings 6/7 are placeholders without gme).
        float claim = 0.0;
        if (pc.matte_on > 0.5) {
            const float cfs = smoothstep(0.5*pc.matte_thresh, 1.5*pc.matte_thresh, texture(u_dissidence,     uv).r);
            const float cbs = smoothstep(0.5*pc.matte_thresh, 1.5*pc.matte_thresh, texture(u_dissidence_bwd, uv).r);
            claim = 0.5 * (cbs - cfs);
