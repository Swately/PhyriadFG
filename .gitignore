# ── Build output ────────────────────────────────────────────────
build-render-assistant/
build*/
*.exe
*.obj
*.pdb
*.spv
*.ilk
*.exp
*.lib

# ── UI (Tauri) — generated / vendored, never versioned ──────────
ui/node_modules/
ui/dist/
ui/src-tauri/target/
# ui/webview2: fixed WebView2 runtime (downloaded MS cab, ~149MB) — re-fetchable, not vendored
ui/webview2/
ui/Microsoft.WebView2*
*.cab
.vscode/

# ── LaTeX intermediates (keep .tex + rendered .pdf/.png) ────────
*.aux
*.log
*.log1
*.log2
*.out
*.toc
*.nav
*.snm
*.vrb
*.synctex.gz

# ── Release artifacts (attached to GitHub releases, not versioned) ──
*.zip

# ── Scratch / diagnostics (gitignored campaign artifacts) ───────
frames/
*.bak
*.rej
*.patch
ra_out*.txt
c7_*.txt
pslab_run/
